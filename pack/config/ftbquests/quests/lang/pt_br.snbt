	quest.74F05A1762C414E6.quest_desc: ["Você completou o caminho do Ocultista EQSMP! Dominou rituais, invocações (foliot/djinni/afrit/marid), armazenamento system e mineração iesnium.", "", "§7Recipes EQSMP que você aprendeu:§r", "§7•§r datura_seeds via apothecary (Botania, sem grass saque)", "§7•§r spirit_attuned_gem via amethyst_shard (mais barato)", "§7•§r spirit_attuned_crystal via amethyst_block (cascade Aglutinado)", "§7•§r spirit_lantern com manasteel_ingot (Botania)", "§7•§r book_of_binding_foliot com aglutinado_magico (Aglutinado Mágico)", "§7•§r book_of_binding_djinni com cristal_mana_pura (Cristal de Mana Pura)", "§7•§r otherstone obrigatório pra mana_pool Botania (Aglutinado Mágico)", "", "Caminhos restantes: Pedra Filosofal (fim de jogo absoluto).", "occultism:book_of_binding_marid", "74F05A1762C414E6", "57E7792012632927", "xp", "2B90E16AFC82227A", "xp_levels", "1A2B3C4D5E6F012C", "1A2B3C4D5E6F0001", "random", "gear", "Você dominou o Ocultista", "2E83C37E7EB2C13D", "checkmark"]
