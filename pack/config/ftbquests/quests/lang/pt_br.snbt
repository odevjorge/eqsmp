	quest.30DACF0F1200FFD0.title: "Waystone de Areia"
	quest.31094F326A7FC887.quest_desc: ["A câmara absorve source dos jarros ao redor pra transformar items. Tudo no caminho do Arcanista passa por aqui.", "", "Aqui ela inclui livingwood na receita — porque madeira viva canaliza source melhor que qualquer outra.", "ars_nouveau:imbuement_chamber", "31094F326A7FC887", "640EBD11DF1BA24F", "xp"]
