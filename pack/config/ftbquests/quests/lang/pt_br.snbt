	quest.36D0073E0AC82656.quest_desc: ["O aparato é o núcleo de criação do Arcanista veterano. Tomos, parchments, items avançado — tudo nasce aqui.", "", "Pra montá-lo, você precisa de um §dNúcleo Cinético§r — mecânica e magia se encontram nesse ponto.", "ars_nouveau:enchanting_apparatus", "36D0073E0AC82656", "7E3336D920A0B98E", "xp"]
