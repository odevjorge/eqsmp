	quest.5909C601B6A937D1.quest_desc: ["Infused picareta: ritual djinni com 1 diamond_pickaxe + 4 spirit_attuned_gem. Vê iesnium_ore (invisível com normal picareta).", "occultism:infused_pickaxe", "5909C601B6A937D1", "6E6D9D3A53A4D303", "xp"]
	quest.5909C601B6A937D1.quest_subtitle: "Picareta que vê iesnium"
	quest.5909C601B6A937D1.title: "Infused Picareta"
	quest.593F35F2A58DB752.quest_desc: ["Capacidade alta e vários slots de §eupgrade§r ao mesmo tempo.", "§7•§r Ideal pro armazém central da sua base.", "Combine com o Controller pra acessar tudo de um ponto só."]
	quest.593F35F2A58DB752.title: "Baú de Diamante"
	quest.596316A02613FA3F.quest_desc: ["Aqui a receita segue outro caminho: 2× manasteel + 2× blaze_powder + 1× §dCristal de Mana Pura§r (Cristal de Mana Pura) → 1 rune_fire.", "botania:rune_fire", "596316A02613FA3F", "5E8D1F9C46A96FF4", "xp"]
	quest.596316A02613FA3F.quest_subtitle: "Cross-mod F3 — runa elemental"
	quest.596316A02613FA3F.title: "Runa do Fogo"
	quest.59A5D0BCF9B9E2D0.quest_desc: ["Armazenamento controlador: storage_base + dimensional_matrix + frame. Acessa inventory infinito (limitado por stabilizers).", "occultism:storage_controller", "59A5D0BCF9B9E2D0", "19EA1A6950C6C64D", "xp"]
	quest.59A5D0BCF9B9E2D0.quest_subtitle: "Armazenamento system completo"
	quest.59A5D0BCF9B9E2D0.title: "Armazenamento Controller"
	quest.5A2AC224F5B13979.quest_desc: ["§dSoul Gem§r de Occultism captura a alma de uma criatura viva — use-a num ser dócil para selar o espírito na gema.", "", "Essa alma capturada é o combustível espiritual do núcleo final."]
	quest.5A2AC224F5B13979.title: "Soul Gem"
	quest.5AA2177BF0CADDE0.quest_desc: ["Ancient Forge no Nether. Mestre das flames e da Ignitium.", "", "§eRecompensa:§r 50 níveis de XP + drop único"]
	quest.5AA2177BF0CADDE0.quest_subtitle: "Senhor das Forjas"
	quest.5AA2177BF0CADDE0.title: "Derrote Ignis"
	quest.5AD3FE37BF6D66D4.quest_desc: ["A §dFloresta Crepuscular§r é uma dimensão de penumbra eterna, repleta de criaturas antigas e tesouros esquecidos.", "", "Use o §6Twilight Forest Portal§r (água + 4 flores em quadrado, jogue um diamante) pra entrar.", "", "§7Lá dentro: 6 bosses na ordem de progressão."]
	quest.5AD3FE37BF6D66D4.quest_subtitle: "O primeiro passo na aventura"
	quest.5AD3FE37BF6D66D4.title: "Entrar na Floresta Crepuscular"
	quest.5AD9297290CBA43C.quest_desc: ["Em grade, esses crafters montam qualquer receita complexa sozinhos. É como ter mil mãos forjando em paralelo.", "", "Você vai precisar deles pra forjar o §dPrecision Mechanism§r — peça crítica do meio de jogo do Create.", "create:mechanical_crafter", "5AD9297290CBA43C", "5597EB0AB38205C0", "xp"]
	quest.5AD9297290CBA43C.quest_subtitle: "Criação automatizada avançada"
	quest.5AD9297290CBA43C.title: "Mechanical Crafter"
	quest.5B03AB38C3D2DC90.quest_desc: ["Clutch desconecta rotação quando recebe redstone — equivalente mecânico de um switch.", "create:clutch", "5B03AB38C3D2DC90", "15CEC1CFEADCDC83", "xp"]
	quest.5B03AB38C3D2DC90.quest_subtitle: "Liga/desliga via redstone"
	quest.5B03AB38C3D2DC90.title: "Clutch"
	quest.5B23C6C5A77DA674.quest_desc: ["Wilden chain (queda da chimera) → componentes de enchanted_chain no apparatus. Combina com archwood + source pra alfsteel.", "ars_nouveau:wilden_horn", "5B23C6C5A77DA674", "1DD3F6E4C5DDDB92", "xp"]
	quest.5B23C6C5A77DA674.quest_subtitle: "Material avançado"
	quest.5B23C6C5A77DA674.title: "Corrente Wilden"
	quest.5B64012A0840B461.quest_desc: ["Lich Tower — uma torre alta no meio da floresta. Tem 3 fases: shielded, projectile, melee.", "", "§eRecompensa:§r 30 níveis de XP + trofeu do boss"]
	quest.5B64012A0840B461.quest_subtitle: "Magister dos mortos"
	quest.5B64012A0840B461.title: "Derrote o Lich"
	quest.5BA8BE35BC4A3C8A.quest_desc: ["Elven spreader: 4× dreamwood + dragonstone + elementium. Velocidade 2× normal, range maior.", "botania:elven_spreader", "5BA8BE35BC4A3C8A", "20A52D8D89D84EBF", "xp"]
	quest.5BA8BE35BC4A3C8A.quest_subtitle: "Spreader Alfheim"
	quest.5BA8BE35BC4A3C8A.title: "Elven Spreader"
	quest.5CC3C7A920431310.quest_desc: ["Obtenha um §6scroll_blood§r e ative-o pra aprender feitiços dessa escola.", "", "§7Scrolls são gerados em estruturas, comprados de wandering traders, ou dropados de mages."]
	quest.5CC3C7A920431310.quest_subtitle: "Feitiços de sangue: dano e dreno"
	quest.5CC3C7A920431310.title: "Escola do Sangue"
	quest.5CC77A9041A3A9A6.quest_desc: ["Dandelifeon simula Conway Game of Life com células (cellular_block). Cada geração = mana. Montagem complexa mas densidade absurda.", "botania:dandelifeon", "5CC77A9041A3A9A6", "73A98EF2980FD2FE", "xp"]
	quest.5CC77A9041A3A9A6.quest_subtitle: "Game of Life mana"
	quest.5CC77A9041A3A9A6.title: "Dandelifeon"
	quest.5D34338946363D24.quest_desc: ["Armazenamento controlador base: 1 obsidian + 4 spirit_attuned_gem + 4 redstone. Componente do storage_controller avançado.", "occultism:storage_controller_base", "5D34338946363D24", "09A8A43EC5D7C72D", "xp"]
	quest.5D34338946363D24.quest_subtitle: "Base de armazenamento"
	quest.5D34338946363D24.title: "Armazenamento Controller Base"
	quest.5D3D2BBC7209A7C8.quest_desc: ["O §eBoneco Vodu§r te §2protege§r contra um tipo específico de dano ou morte.", "", "§7•§r Equipe-o e ele se consome ao absorver aquele perigo no seu lugar.", "§7•§r Há variantes para queda, fogo, afogamento e outras ameaças: escolha conforme o risco."]
	quest.5D3D2BBC7209A7C8.quest_subtitle: "Proteção contra a morte"
	quest.5D3D2BBC7209A7C8.title: "Boneco Vodu"
	quest.5DF5B59BB7DEE26C.quest_desc: ["Aqui a receita segue outro caminho: 1 §damethyst shard§r jogado em spirit_fire → 1 spirit_attuned_gem.", "", "Era diamond no vanilla; agora é amethyst_shard (mais barato). Gem usada em chalks coloridas, spirit_lantern, infused picareta.", "occultism:spirit_attuned_gem", "5DF5B59BB7DEE26C", "3F2E63E5363AB221", "xp"]
	quest.5DF5B59BB7DEE26C.quest_subtitle: "Cross-mod — gema espiritual"
	quest.5DF5B59BB7DEE26C.title: "Gema Sintonizada"
	quest.5E11C9C5F7912BED.quest_desc: ["Manasteel sword tem damage similar diamond. Consome mana em vez de durabilidade.", "botania:manasteel_sword", "5E11C9C5F7912BED", "115F2C1A2C0E2B43", "xp"]
	quest.5E11C9C5F7912BED.quest_subtitle: "Espada de mana"
	quest.5E11C9C5F7912BED.title: "Manasteel Sword"
	quest.5E1FA86D744121E2.quest_desc: ["A §eCaçarola§r cuida de molhos e cozidos mais delicados.", "", "Ideal para §7•§r reduções, cremes e pratos que pedem fogo brando.", "Mais um utensílio que fica com você depois do preparo."]
	quest.5E1FA86D744121E2.title: "Caçarola"
	quest.5E570F77EB109F10.quest_desc: ["A §eTábua de Recall§r te §bteleporta§r direto para o seu último §6túmulo§r.", "", "§7•§r Salva sua vida quando você morre em local distante ou perigoso.", "§7•§r Combine com a Chave do Túmulo para recuperar tudo num piscar de olhos."]
	quest.5E570F77EB109F10.quest_subtitle: "Teleporta até seu túmulo"
	quest.5E570F77EB109F10.title: "Tábua de Recall"
	quest.5EDA4644FC22BCC1.quest_desc: ["Aura ring regenera ~1 mana/tick passivamente. Combinada com mana_ring greater pra autossustentabilidade.", "botania:aura_ring", "5EDA4644FC22BCC1", "23E49B359B7E76FB", "xp"]
	quest.5EDA4644FC22BCC1.quest_subtitle: "Gera mana passivamente"
	quest.5EDA4644FC22BCC1.title: "Anel de Aura"
	quest.5F0EEF797725B751.quest_desc: ["Você completou o caminho do Arcanista EQSMP! Dominou glifos, automação com familiars, rituais e venceu o Wilden Chimera.", "", "§7Recipes EQSMP que você aprendeu:§r", "§7•§r imbuement_chamber + livingwood (Botania)", "§7•§r source_gem via mana_diamond (Aglutinado-mid Botania+Occultism)", "§7•§r source_gem via spirit_attuned_crystal (Aglutinado cascade)", "§7•§r source_jar + mana_pearl (Botania)", "§7•§r dominion_wand + livingwood_twig (Botania)", "", "Próximos caminhos: Occultism, Pedra Filosofal.", "ars_nouveau:wilden_horn", "5F0EEF797725B751", "662324FB251C17AC", "xp", "244C6850D12D3E82", "xp_levels", "1A2B3C4D5E6F0129", "1A2B3C4D5E6F0001", "random", "gear", "Você dominou o Arcanista", "507BDFF84998AAEF", "checkmark"]
	quest.5F0EEF797725B751.quest_subtitle: "Você dominou o Arcanista"
	quest.5F0EEF797725B751.title: "Mestria Arcana"
	quest.5F8C39AE9EE75AE5.quest_desc: ["Wormhole frame conecta storage_actuator a output remoto. Crítico pra armazenamento anywhere.", "occultism:storage_remote", "5F8C39AE9EE75AE5", "00B444A4618269C5", "xp"]
	quest.5F8C39AE9EE75AE5.quest_subtitle: "Acesso armazenamento remoto"
	quest.5F8C39AE9EE75AE5.title: "Wormhole Frame"
	quest.5FE3E587B6564965.quest_desc: ["O §ePão de Milho§r é um assado simples e saciante.", "", "Use milho moído e a forma de forno para prepará-lo.", "Ótima fonte de fome §7•§r para levar em viagens."]
	quest.5FE3E587B6564965.title: "Pão de Milho"
	quest.6070A4C94C4F2242.quest_subtitle: "Ponte da rede"
	quest.6070A4C94C4F2242.title: "Interface"
	quest.607C4F73A1BEDC7A.quest_desc: ["§eÁgua Fresca§r é a base de quase toda receita líquida do Pam's.", "", "Obtenha enchendo um §7•§r balde ou garrafa direto em uma fonte de água.", "Guarde sempre algumas: sopas, massas e bebidas pedem ela."]
	quest.607C4F73A1BEDC7A.quest_subtitle: "Hidratação"
	quest.607C4F73A1BEDC7A.title: "Água Fresca"
	quest.607E53E822CD3AB0.quest_desc: ["Receita reescrita: §c8 andesite + 1 Aglutinado Mágico → 4 andesite_alloy§r.", "", "As receitas vanilla (iron + andesite mixing) foram removidas. A única alternativa preservada é decompact do andesite_alloy_block."]
	quest.607E53E822CD3AB0.quest_subtitle: "Create destravado"
	quest.607E53E822CD3AB0.title: "Andesite Alloy via Aglutinado"
	quest.60B38AD0A66B6A9A.quest_desc: ["O §6Depot§r de Create é a bancada estática onde itens repousam para serem processados por um §6Deployer§r.", "", "É o palco da montagem sequenciada que dará à luz o núcleo espiritual."]
	quest.60B38AD0A66B6A9A.title: "Depot"
	quest.60E85A3D245613A5.quest_desc: ["Converte uma gaveta comum num formato §eatualizado§r ou de outro tipo.", "§7•§r Use pra migrar gavetas antigas sem perder o conteúdo.", "Mantém seus itens enquanto você troca o bloco por uma versão melhor."]
	quest.60E85A3D245613A5.title: "Melhoria de Conversão"
	quest.614B009BBD9EAE92.quest_desc: ["§4Cataclysm§r traz 7 bosses únicos espalhados em estruturas customizadas pelo mundo.", "", "Cada um tem mecânicas próprias e drops poderosos. Não são fáceis — prepare-se.", "", "§7Estruturas geram naturalmente em biomas específicos."]
	quest.614B009BBD9EAE92.quest_subtitle: "Bosses dimensionais de elite"
	quest.614B009BBD9EAE92.title: "Cataclysm — Os Sete Pesadelos"
	quest.61C8614113BD83F9.quest_desc: ["No §aRunic Altar§r você reúne §aMana Pearl§r, §aMana Diamond§r e o §eNúcleo Cinético§r, alimentando mana até a runa se completar.", "", "É aqui que Botania e Create se fundem para gerar o próximo coração."]
	quest.61C8614113BD83F9.title: "Forja Rúnica"
	quest.61D5630307136C4C.quest_desc: ["Blaze burner aceita combustíveis variados pra fornecer calor a basins, crucibles, etc. Heated vs superheated muda receitas disponíveis (blaze cake = superheated).", "create:blaze_burner", "61D5630307136C4C", "4032BD4534FC1FAE", "xp"]
