	quest.15597489E4770386.quest_desc: ["Gearshift inverte a direção do eixo quando recebe redstone. Útil pra deployers e pumps reversíveis.", "create:gearshift", "15597489E4770386", "00C29A27B9D2B7C4", "xp"]
