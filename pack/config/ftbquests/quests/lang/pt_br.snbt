	quest.2F2B9FB9D7D35497.quest_desc: ["Mundane belt: 4 magebloom_fiber + 1 string + 1 couro. Equipa em curio \"belt\" pra espaços de feitiço parchments.", "ars_nouveau:mundane_belt", "2F2B9FB9D7D35497", "532E4C4FF1A3A25D", "xp"]
