	quest.1E13439C75C88343.quest_desc: ["Crie ou obtenha o §6Tomo de Ouro§r. Cada tier permite §emais feitiços inscritos§r e §ecasts mais potentes§r.", "", "§7Crafting: receita similar ao spell book base, com ingrediente do tier correspondente."]
