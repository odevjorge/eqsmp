	quest.19D8E5E2A48177D3.quest_desc: ["Infused lenses (eye espaço via curio) revelam blocos otherworld sem precisar picareta específico.", "occultism:infused_lenses", "19D8E5E2A48177D3", "5A51DCC506940669", "xp"]
