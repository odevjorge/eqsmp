	quest.1421D434596C84D1.quest_desc: ["Dimensional matrix: ritual djinni com 1 storage_base + 1 nether_star + items raros. Coração do sistema de armazenamento.", "occultism:dimensional_matrix", "1421D434596C84D1", "455D9ED8E10E34A9", "xp"]
