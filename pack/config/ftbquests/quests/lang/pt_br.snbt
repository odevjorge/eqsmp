	quest.13AA5F368949DF26.quest_desc: ["Boss inicial da Floresta Crepuscular. Encontre em ruínas de pedra musgosa.", "", "§eRecompensa:§r 20 níveis de XP + trofeu do boss"]
	quest.13AA5F368949DF26.quest_subtitle: "A serpente das ruínas"
	quest.13AA5F368949DF26.title: "Derrote a Naga"
	quest.13F667C677069107.quest_desc: ["Coloque uma pure_daisy ao lado de logs (não planks!) — converte gradualmente em livingwood. Material base pra mana_spreader, mana_pylon e várias outras estruturas.", "botania:livingwood", "13F667C677069107", "3CFE71FB96516873", "xp"]
