	quest.2A7D620BAE54E3A4.quest_desc: ["datura_seeds NÃO quedaam mais de grass/tall_grass.", "", "§eÚnica forma:§r petal_apothecary (Botania) com 2 white_petal + 2 purple_petal + 1 black_petal + seed_reagent → 1 datura_seeds.", "occultism:datura_seeds", "2A7D620BAE54E3A4", "6D04F627E67EF75D", "xp"]
