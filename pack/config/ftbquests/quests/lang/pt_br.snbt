	quest.44FC81F643639B8D.quest_desc: ["Vincula a gaveta a §evocê§r: só o dono consegue abrir e usar.", "§7•§r Protege seu estoque em servidor de outros jogadores.", "Ideal pra baús e gavetas com itens valiosos."]
