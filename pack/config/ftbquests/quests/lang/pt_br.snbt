	quest.2E733F6BCC7C7D34.quest_desc: ["Brewery cria poções customizadas Botania (absorção, allure, clear sight, etc). Pétalas + livingrock + reagente.", "botania:brewery", "2E733F6BCC7C7D34", "79F9CAF2ABDE75AB", "xp"]
