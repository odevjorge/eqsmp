	quest.72E4F7AF06392851.quest_desc: ["Monte pentacle de chalk white_impure + 4 sacrificial_bowl + 1 golden_sacrificial_bowl + 1 candle_white. Jogue ritual_dummy + ingredients no golden → ativa ritual.", "", "Comece com summon_foliot_crusher pra ver o sistema funcionar.", "occultism:ritual_dummy/summon_foliot_crusher", "72E4F7AF06392851", "2C445678B05A37C7", "xp"]
