	quest.420FF5CF6EE201F7.quest_desc: ["Fluid pipes movem líquidos entre tanks, basins, e máquinas. Conectam automaticamente em até 16 blocos. Combinam com mechanical_pump pra pressure.", "create:fluid_pipe", "420FF5CF6EE201F7", "01666F298F0D2533", "xp"]
