	quest.10A59234C40DB59C.title: "Purified Ink"
	quest.10ECCC51CDCDAB60.quest_desc: ["O §6Fragmento Sintonizado§r vincula Placas de Teletransporte entre si, formando uma rede de teleporte com escopo de destinos.", "waystones:attuned_shard", "10ECCC51CDCDAB60", "17FF1C33B68AF7F8", "xp_levels"]
	quest.10ECCC51CDCDAB60.quest_subtitle: "Vincule seus Placas de Teletransporte numa rede"
	quest.10ECCC51CDCDAB60.title: "Fragmento Sintonizado"
	quest.1119A0C2942258B8.quest_desc: ["Como parte da penitência, a Deusa &etomou o gume&r das ferramentas forjadas pela mão mortal.", "Madeira, pedra, ferro, ouro, diamante e netherite &7perderam a força e a durabilidade&r. Elas ainda servem — mas mal."]
	quest.1119A0C2942258B8.title: "As Ferramentas Mortais"
	quest.1144C819F885DE00.quest_desc: ["Armazenamento remote: 1 controlador + 1 wormhole_frame. Acessa o armazenamento de qualquer lugar (item portátil).", "occultism:storage_remote", "1144C819F885DE00", "0B804178C93C6AFA", "xp"]
	quest.1144C819F885DE00.quest_subtitle: "Acesso remoto"
	quest.1144C819F885DE00.title: "Armazenamento Remote"
	quest.1166CF581183294D.quest_desc: ["A §ePanela§r é o utensílio das §6sopas e ensopados§r.", "", "Junte água fresca, vegetais e carnes para pratos quentes que enchem bem a barra de fome.", "Reutilizável: uma vez feita, cozinhe à vontade."]
	quest.1166CF581183294D.quest_subtitle: "Sopas e ensopados"
	quest.1166CF581183294D.title: "Panela"
	quest.11F1769AC021A9A6.quest_desc: ["Hose pulley aspira fluidos de body de líquido (oceano, lago, lava). Source infinita se body é > 10000 blocos.", "create:hose_pulley", "11F1769AC021A9A6", "2CF91535A58A43AF", "xp"]
	quest.11F1769AC021A9A6.quest_subtitle: "Sucção infinita de fluidos"
	quest.11F1769AC021A9A6.title: "Hose Pulley"
	quest.12285E91B2823CD6.quest_desc: ["Em grade, esses crafters montam qualquer receita complexa sozinhos. É como ter mil mãos forjando em paralelo.", "", "Você vai precisar deles pra forjar o §dPrecision Mechanism§r — peça crítica do meio de jogo do Create."]
	quest.12285E91B2823CD6.quest_subtitle: "Criação automatizada"
	quest.12285E91B2823CD6.title: "Mechanical Crafter"
	quest.12CE6E9875DD1591.quest_desc: ["Canhão de Esquema dispara blocos pra construir uma esquema salva. Combina com esquema e pena (próxima quest) e brick of fuel.", "create:schematicannon", "12CE6E9875DD1591", "48EFA13F3F593537", "xp"]
	quest.12CE6E9875DD1591.quest_subtitle: "Construa estruturas automaticamente"
