	quest.142572AABD3DFC3A.quest_desc: ["Para forjar: 1 §6spirit attuned crystal§r no imbuement_chamber → 4 source_gem + 1000 source mana.", "", "Path 4× eficiente em mass production. Crystal vem de amethyst_block (momento decisivo — Aglutinado Mágico).", "ars_nouveau:source_gem", "142572AABD3DFC3A", "6057B872DF053AA6", "xp"]
