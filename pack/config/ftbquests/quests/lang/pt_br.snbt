	quest.139CAC5805D05307.quest_desc: ["Source gem block: 9 source_gem → 1 block. Armazenamento + decoração + componente de várias estruturas.", "ars_nouveau:source_gem_block", "139CAC5805D05307", "2D80846FDD0AA731", "xp"]
