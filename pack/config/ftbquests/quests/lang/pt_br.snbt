	quest.63942FA596F0D42B.title: "Gaia Spreader"
	quest.63E48AD41D82757F.quest_desc: ["O §bEnchanting Apparatus§r de Ars Nouveau foi destravado pelo §eNúcleo Cinético§r.", "", "Cercado de pedestais, ele transforma reagentes em itens encantados — a porta da magia Source nas fases seguintes."]
	quest.63E48AD41D82757F.title: "Enchanting Apparatus Liberado"
	quest.642032C8973A2BA9.quest_desc: ["Transmissão por correntes transferem rotação entre eixos paralelos a até 3 blocos de distância. Bom pra layout compacto.", "create:encased_chain_drive", "642032C8973A2BA9", "0DEC78EF6ADFE179", "xp"]
