	quest.7322CCE81684BE59.quest_desc: ["Você completou o caminho do Druida EQSMP! Dominou mana, runas (com cristal Cristal de Mana Pura como requisito), terrasteel, Gaia e Alfheim.", "", "§7Recipes EQSMP que você aprendeu:§r", "§7•§r mana_pool/diluted_pool com otherstone (Aglutinado Mágico)", "§7•§r runic_altar com nucleo_cinetico (Núcleo Cinético)", "§7•§r runas elementais com cristal_mana_pura (Cristal de Mana Pura)", "§7•§r mana_pylon com source_gem (Ars)", "", "Próximos caminhos: Ars Nouveau, Occultism, Pedra Filosofal.", "botania:gaia_pylon", "7322CCE81684BE59", "0E48EA5B34B42A67", "xp", "4CB24D6EC5425209", "xp_levels", "1A2B3C4D5E6F012A", "1A2B3C4D5E6F0001", "random", "gear", "Você dominou o Druida", "078A1B823AF67F55", "checkmark"]
