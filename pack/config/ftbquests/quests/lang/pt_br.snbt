	quest.14CE03D862C378EC.quest_subtitle: "Vira blocos automaticamente"
	quest.14CE03D862C378EC.title: "Melhoria: Compactação"
	quest.151AC074067A49BD.quest_desc: ["Ritual binding tablet permite converter shards em charms. Executa no brazier com shards + base items.", "ars_nouveau:ritual_binding", "151AC074067A49BD", "4D7C38BC87675D00", "xp"]
