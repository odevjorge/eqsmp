	quest.63942FA596F0D42B.quest_desc: ["Gaia spreader: 4× gaia_ingot + dreamwood + dragonstone. Velocidade e capacidade máximas. Usado em fazendas avançado.", "botania:gaia_spreader", "63942FA596F0D42B", "27C83F19E8EF1EC4", "xp"]
