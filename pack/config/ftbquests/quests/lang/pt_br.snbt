	quest.309DC7FA77D19D80.title: "Potion Flask"
	quest.30B5FFC763CBC1E5.quest_desc: ["O §eTomo de Reparo§r §2conserta§r a durabilidade do seu equipamento.", "", "§7•§r Restaura armas, armaduras e ferramentas sem precisar de bigorna.", "§7•§r Mantenha o equipamento favorito sempre em forma."]
	quest.30B5FFC763CBC1E5.quest_subtitle: "Conserta equipamento"
	quest.30B5FFC763CBC1E5.title: "Tomo de Reparo"
	quest.30DACF0F1200FFD0.quest_desc: ["A §eWaystone de Areia§r é a variante §bestética§r perfeita para bases no §6deserto§r.", "", "§7•§r Ative-a e teleporte-se entre ela e qualquer outra waystone da rede.", "§7•§r Função idêntica à waystone padrão, só muda o visual arenoso."]
