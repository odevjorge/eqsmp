	quest.131FD257771A6236.quest_desc: ["§5The Keeper§r — wraith encontrado em ruínas. Boss de elemento §dender§r.", "", "Drop: §6spell scrolls raros§r + §6keeper soul§r."]
	quest.131FD257771A6236.quest_subtitle: "Wraith arcano"
	quest.131FD257771A6236.title: "Chefe: The Keeper"
	quest.1384646025CA3D53.quest_desc: ["Mycelial link gera mana de mushroom fazendas. Útil em swamp/mushroom_island.", "ars_nouveau:mycelial_sourcelink", "1384646025CA3D53", "07C90040FFF61F94", "xp"]
