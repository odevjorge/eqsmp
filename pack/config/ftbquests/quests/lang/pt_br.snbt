	quest.1FFA1B0C43DE05B3.quest_desc: ["Agricarnation acelera crescimento de cultivos ao redor. Mana cost por crop. Combina com vegetal_baby pra fazendas massivas.", "botania:agricarnation", "1FFA1B0C43DE05B3", "03EB692AA9E4B9C4", "xp"]
