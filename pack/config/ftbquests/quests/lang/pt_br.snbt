	quest.3D3B6799C11FA917.quest_desc: ["Aqui a receita segue outro caminho: 2× manasteel + 2× prismarine_crystals + 1× §dCristal de Mana Pura§r (Cristal de Mana Pura) → 1 rune_water.", "", "8000 mana no runic_altar.", "botania:rune_water", "3D3B6799C11FA917", "07196EF105DEA541", "xp"]
