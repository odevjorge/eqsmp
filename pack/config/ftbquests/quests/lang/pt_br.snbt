	quest.31094F326A7FC887.title: "Imbuement Chamber"
	quest.311EB32138F7A3A1.quest_desc: ["Anel de Thor mina padrão 3x3x1 simultaneamente. Combo com manasteel_pickaxe pra mineração avançada.", "botania:thor_ring", "311EB32138F7A3A1", "625C707DB379C763", "xp"]
