	quest.652CB209F9C8DF8A.quest_desc: ["A Quimera Wilden é o chefe da Ars Nouveau. Invoque-a com um chifre wilden no braseiro ritual.", "", "Recompensas: asas pra voo permanente, espinho pra criação avançada.", "ars_nouveau:wilden_horn", "652CB209F9C8DF8A", "3AEA35DFB51512A3", "xp"]
