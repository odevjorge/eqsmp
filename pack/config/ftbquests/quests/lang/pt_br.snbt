	quest.2BB41BF9FFF5F2E1.title: "Brass Encapsulamento"
	quest.2BDCFE3F41A97BF9.quest_desc: ["Aqui a receita segue outro caminho: 6 iron_nugget + 1 spirit_attuned_gem + 3 §dmanasteel§r → spirit_lantern.", "", "Lantern emite luz mística e bloqueia aparições de criaturas em raio grande. Cross-mod Botania.", "occultism:spirit_lantern", "2BDCFE3F41A97BF9", "1E56C568184D9A9B", "xp"]
