	quest.3E182C9C9E7C7BB4.quest_desc: ["Primeira liga do Engenheiro. Aqui ela exige um §dAglutinado Mágico§r no centro — quem ainda não passou pelo caminho do Druida vai precisar voltar atrás.", "", "Sem essa liga, nenhuma máquina toma forma. É a porta de entrada do Create.", "create:andesite_alloy", "3E182C9C9E7C7BB4", "156CC37F81F4B965", "xp"]
