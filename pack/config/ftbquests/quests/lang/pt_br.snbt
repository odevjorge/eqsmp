	quest.1946293FE32510F3.quest_subtitle: "Mineração infinita"
	quest.1946293FE32510F3.title: "Minerador Marid (avançado)"
	quest.19D72A7F5EE326F5.quest_desc: ["Kekimurus come cake (vanilla) pra gerar mana — ~120k mana por cake. Auto-feed via cake-stacking belt do Create.", "botania:kekimurus", "19D72A7F5EE326F5", "257750CBA4DFB6F3", "xp"]
