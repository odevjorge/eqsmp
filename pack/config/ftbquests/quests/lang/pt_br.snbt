	quest.168FAA46D89F457B.title: "Panquecas"
	quest.16D79B3A3A9C95FB.quest_desc: ["Dark Tower no Twilight. Boss endgame da Floresta Crepuscular.", "", "§eRecompensa:§r 70 níveis de XP + trofeu do boss"]
	quest.16D79B3A3A9C95FB.quest_subtitle: "Senhor da Torre Escura"
	quest.16D79B3A3A9C95FB.title: "Nível 6: Ur-Ghast"
	quest.16EDE5F05169464C.quest_desc: ["Spirit fire: monte pentacle white impure + flint_and_steel em center → spirit_fire ativa. Joga items pra converter (cobblestone→otherstone, amethyst_block→spirit_attuned_crystal, etc).", "occultism:spirit_fire", "16EDE5F05169464C", "3C1C96277D2B9B1D", "xp"]
	quest.16EDE5F05169464C.quest_subtitle: "Ritual de fogo espiritual"
	quest.16EDE5F05169464C.title: "Spirit Fire"
	quest.1706DED5F3EDA6B9.quest_desc: ["Explore os cantos §esombrios e os campos de cogumelo§r.", "", "Em terras úmidas e escuras nascem as §6hortas selvagens§r mais incomuns.", "Quebre-as §7•§r e leve para casa ingredientes que poucos conhecem."]
	quest.1706DED5F3EDA6B9.title: "Encontrei e quebrei a horta"
	quest.17483F40DBEC0AFB.quest_desc: ["§eEsse capítulo guia a progressão de bosses do EQSMP.§r", "", "A linha principal cobre 8 marcos — bosses essenciais que abrem o caminho até o endgame.", "Side quests adicionam variedade: bosses elementais, modos hard, e mestres únicos de cada mod.", "", "§7Comece pelo Naga (mais fácil) e avance até o Harbinger (mais difícil)."]
	quest.17483F40DBEC0AFB.quest_subtitle: "Confronte os bosses do mundo"
	quest.17483F40DBEC0AFB.title: "O Caminho do Caçador"
	quest.17D98576B8A56FF4.quest_desc: ["A salvação está em &btranscender o comum&r. Ferramentas e armas além das mortais — &6Silent Gear&r, magia, engenharia — não carregam a maldição e batem &amais forte&r.", "Trilhe os &eCaminhos dos Mods&r e forje as suas."]
	quest.17D98576B8A56FF4.title: "Forje o Seu Próprio Caminho"
	quest.18D3E4535B857760.quest_desc: ["Dragon familiar: ritual afrit + ender_dragon scales. Combat support + auto-flight.", "occultism:familiar_ring", "18D3E4535B857760", "4CB7FA9301707C7D", "xp"]
