	quest.66082991AED39DA0.quest_desc: ["§7Lembrete Núcleo Espiritual EQSMP:§r o ars_nouveau:ritual_brazier (Ars) usa §dNúcleo Espiritual§r no craft.", "", "Brazier conecta Ars + Occultism via rituais. Avançado ritualistic.", "ars_nouveau:ritual_brazier", "66082991AED39DA0", "53AF58866555EA8B", "xp"]
