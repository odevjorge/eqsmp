	quest.3005D251021F3B39.title: "Secundário: Minoshroom"
	quest.3034F34D9C9F2239.quest_desc: ["A picareta de iesnium é o ferramenta avançada do Ocultista. Minera minério de iesnium (invisível pra picaretas comuns) e abre o caminho pro nível marid.", "", "Marid são os espíritos mais poderosos — quem chega aqui dominou o ocultismo inteiro.", "occultism:iesnium_pickaxe", "3034F34D9C9F2239", "7FECB42575F48CEF", "xp"]
