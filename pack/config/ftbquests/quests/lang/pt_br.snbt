	quest.2F184971F6DDD9FE.quest_desc: ["Mate um §cnecromancer§r. Esses mages são spawnados em §6Mage Towers§r e dropam peças de equipamento + scrolls de escola.", "", "§eRecompensa:§r XP + chance de drop de armor set ou scroll."]
