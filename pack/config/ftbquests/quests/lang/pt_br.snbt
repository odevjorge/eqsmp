	quest.2E5C33EA9550EA9B.quest_desc: ["Livro Marid: ritual afrit + iesnium_ingot + nether_star. Marid são os espíritos mais poderosos.", "occultism:book_of_binding_marid", "2E5C33EA9550EA9B", "25C8C9783A432005", "xp"]
