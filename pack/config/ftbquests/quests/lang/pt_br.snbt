	quest.62148A6DDE69428E.title: "Pure Daisy"
	quest.6274B936460CBB82.quest_desc: ["O §bRitual Brazier§r de Ars Nouveau foi destravado pelo §eNúcleo Espiritual§r.", "", "É o braseiro dos rituais mágicos mais avançados — o ápice da automação Source."]
	quest.6274B936460CBB82.title: "Ritual Brazier Liberado"
	quest.62A606CBC3205F0D.quest_desc: ["Crie ou obtenha o §6Tomo de Ferro§r. Cada tier permite §emais feitiços inscritos§r e §ecasts mais potentes§r.", "", "§7Crafting: receita similar ao spell book base, com ingrediente do tier correspondente."]
	quest.62A606CBC3205F0D.quest_subtitle: "+2 espaços"
	quest.62A606CBC3205F0D.title: "Tomo de Ferro"
