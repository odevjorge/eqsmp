	quest.143A3595A3A9E8E8.quest_desc: ["Mana distributor recebe mana de UM spreader e redistribui pra até 4 spreaders adjacentes. Útil pra alimentar fazendas múltiplas.", "botania:mana_distributor", "143A3595A3A9E8E8", "78081CFC12598258", "xp"]
