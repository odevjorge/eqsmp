	quest.2C39178B382722A8.quest_desc: ["O §eAglutinado Mágico§r da primeira fase retorna — e desta vez será consumido de vez.", "", "Ele entrega ao núcleo final o elo original que uniu Create, Botania e Occultism."]
	quest.2C39178B382722A8.title: "Aglutinado Mágico (F1)"
