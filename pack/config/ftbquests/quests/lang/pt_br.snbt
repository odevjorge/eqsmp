	quest.336E7EADEB3E226A.title: "Anel de Magnetização"
	quest.33AC8FC4874F9ABC.quest_desc: ["§cCursed Núcleo Cinético§r é a forma corrompida e instável do núcleo, cuspida crua pelo §6Mechanical Crafter§r.", "", "O movimento bruto ainda não foi domado. Ele precisa ser purificado por um ritual de Occultism antes de servir."]
	quest.33AC8FC4874F9ABC.title: "Cursed Núcleo Cinético"
