	quest.3BA9C2299B88C42E.title: "Meia-Gaveta"
	quest.3BBA4B57171FCE82.quest_desc: ["Terra plate é estrutura multi-bloco que recebe ingredients e mana pra forjar terrasteel. Crafte com 4 livingrock + 1 mana_diamond + 4 manasteel_ingot.", "botania:terra_plate", "3BBA4B57171FCE82", "1910B75593F3C438", "xp"]
	quest.3BBA4B57171FCE82.quest_subtitle: "Forja do terrasteel"
	quest.3BBA4B57171FCE82.title: "Terra Plate"
	quest.3BE6BD7EE8F56235.quest_desc: ["§eNúcleo Espiritual§r — o marco final desta jornada. A §dSoul Gem§r e os três núcleos anteriores convergem numa única obra estável.", "", "Create, Botania, Ars e Occultism num só objeto. Ele destrava §bArs§r e o §2Terrasteel§r de Botania."]
	quest.3BE6BD7EE8F56235.title: "O Núcleo Espiritual"
	quest.3BFF59F53C1A846E.quest_desc: ["Jogue o Cursed Aglutinado num Mana Pool com pelo menos §b50.000 mana§r.", "", "Esse é o item-signatura da F1: ele destrava §eCreate§r (andesite_alloy), §eBotania§r (pools de pedra preta) e §eOccultism§r (binding foliot).", "", "Cada outro mod vai exigir Aglutinado em seus próximos tiers."]
	quest.3BFF59F53C1A846E.quest_subtitle: "O coração da F1"
	quest.3BFF59F53C1A846E.title: "§6Aglutinado Mágico"
	quest.3C17415BAD9B6370.quest_desc: ["Faça §e4§r vitaminas do Pam's.", "pamhc2foodextended:apricotsmoothieitem", "3C17415BAD9B6370", "5E31ED99FD55459E", "xp_levels"]
	quest.3C17415BAD9B6370.quest_subtitle: "45 receitas no Pam's"
	quest.3C17415BAD9B6370.title: "Vitaminas"
	quest.3C4527C189F0544B.quest_desc: ["Lich Tower. Aprenda a desviar de projéteis arcanos. Drop: Lich Crown.", "", "§eRecompensa:§r 30 níveis de XP + trofeu do boss"]
	quest.3C4527C189F0544B.quest_subtitle: "Magister dos mortos"
	quest.3C4527C189F0544B.title: "Nível 2: Lich"
	quest.3C75FD2842D5A444.quest_desc: ["§9BOMD§r adiciona 4 bosses únicos, cada um em um bioma específico:", "", "§7- Gauntlet — Plains/Savanna", "§7- Lich — Snowy biomes", "§7- Obsidilith — End", "§7- Void Blossom — Mushroom Islands", "", "Cada um dropa uma Soul Star — material endgame raro."]
	quest.3C75FD2842D5A444.quest_subtitle: "4 bosses elementais"
	quest.3C75FD2842D5A444.title: "Bosses of Mass Destruction"
	quest.3CF2BD950F857013.quest_desc: ["Enquanto os outros forjavam metal, o Druida isolou-se nos &2bosques profundos&r, convencido de que a &5Pedra Filosofal&r não deveria ser construída, mas &acultivada.&r Ele manipulou a genética das flores místicas ao extremo, forçando &eportais instáveis&r para &2Alfheim&r e desafiando os &aGuardiões de Gaia&r, na tentativa de fundir &2Terrasteel&r com a própria alma da natureza para gerar uma &5semente de poder infinito&r."]
	quest.3CF2BD950F857013.quest_subtitle: "A Busca"
	quest.3CF2BD950F857013.title: "O Druida (Botania)"
	quest.3D24D99C2D136D92.quest_desc: ["Mystical flowers aparecem naturalmente. Use bone meal em qualquer grass pra acelerar. Vai precisar de todas as 16 cores em algum momento — sair colhendo já.", "botania:white_mystical_flower", "3D24D99C2D136D92", "481ABF37FF4EBD92", "xp"]
