	quest.3D5E79BB273EBCA9.quest_desc: ["Iesnium_ore aparece no nether só visível com infused_pickaxe ou otherworld_goggles. Queda iesnium_dust.", "occultism:iesnium_ore", "3D5E79BB273EBCA9", "16D390CE53E2A2A4", "xp"]
