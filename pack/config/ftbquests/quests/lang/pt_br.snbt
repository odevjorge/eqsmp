	quest.15597489E4770386.title: "Gearshift"
	quest.156570B45AB0518D.quest_desc: ["Como a §eColeta§r, mas atrai itens e XP de §blonge§r até você.", "§7•§r O raio é bem maior — limpa o chão de uma área inteira.", "Cuidado pra não puxar o que você não quer; use os filtros."]
	quest.156570B45AB0518D.quest_subtitle: "Atrai itens de longe"
	quest.156570B45AB0518D.title: "Melhoria: Ímã"
	quest.159F86B53CE63848.quest_desc: ["§2Wilden Chimera§r — boss da Ars Nouveau. Convoque com §6Wilden Chimera Spawn Egg§r ou invoque no §6Ritual Brazier of Wilden Summoning§r.", "", "3 fases (defender/hunter/stalker), cada uma com mecânicas próprias.", "", "§eRecompensa:§r 50 níveis de XP + Wilden Trophy"]
	quest.159F86B53CE63848.quest_subtitle: "A fera selvagem da floresta"
	quest.159F86B53CE63848.title: "Derrote a Wilden Chimera"
	quest.15C4F7F1763E716E.quest_desc: ["Vitalic link gera mana via aparição de criaturas próximo. Bom pra fazendas de criaturas.", "ars_nouveau:vitalic_sourcelink", "15C4F7F1763E716E", "79E6B0FA395A1851", "xp"]
	quest.15C4F7F1763E716E.quest_subtitle: "Link de mana via vida"
	quest.15C4F7F1763E716E.title: "Source Link Vitalic"
	quest.15E2785AE7B5C110.quest_desc: ["Há 70+ glifos disponíveis no Ars. Crie uma coleção de pelo menos 25 — chamado pra apprentice. Cada glifo aberta no scribes_table.", "ars_nouveau:blank_glyph", "15E2785AE7B5C110", "5910EBEDB3B62D02", "xp"]
	quest.15E2785AE7B5C110.quest_subtitle: "Aprenda 25+ glifos"
	quest.15E2785AE7B5C110.title: "Coleção de Glifos"
	quest.16011FCD6C61AA02.quest_desc: ["A gema source é a moeda de mana do Arcanista. Sem ela, nada se imbui, nada se canaliza, nada se enchanta.", "", "Há dois caminhos pra obtê-la:", "§71)§r jogue uma §dmana diamond§r no fogo espiritual dos ocultistas — uma gema sai", "§72)§r coloque um §dspirit attuned crystal§r na imbuement chamber — quatro gemas saem (mas exige o caminho completo do Druida + Aglutinado)"]
	quest.16011FCD6C61AA02.quest_subtitle: "Base de tudo Ars"
	quest.16011FCD6C61AA02.title: "Source Gem"
	quest.16035ED5ED581BED.quest_desc: ["Afrit essence: ritual afrit (com nether_star) → essência. Usada em demonic_machine receitas.", "occultism:afrit_essence", "16035ED5ED581BED", "78B089A886311EBF", "xp"]
	quest.16035ED5ED581BED.quest_subtitle: "Essência demoníaca"
	quest.16035ED5ED581BED.title: "Afrit Essence"
	quest.163565E425D947A6.quest_desc: ["Há ~10 formas Ars: projétil, toque, em si, área, raio, sob os pés, etc. Cada uma define COMO o feitiço se manifesta. Coloque ao MENOS 5 formas diferentes no scribes_table.", "ars_nouveau:glyph_orbit", "163565E425D947A6", "609BA2BEF3159563", "xp"]
	quest.163565E425D947A6.quest_subtitle: "Formas básicas e avançadas"
	quest.163565E425D947A6.title: "Coleção de Formas (Glifos)"
	quest.168FAA46D89F457B.quest_desc: ["§eMassa§r + §eForma§r.", "pamhc2foodextended:pancakesitem", "168FAA46D89F457B", "5865474D0D5699A2", "xp_levels"]
