	quest.2DFD01E33932BE0C.quest_desc: ["Há 4 archwood biomes: cascading (azul), blazing (vermelho), vexing (roxo), flourishing (verde). Cada um aparição diferentes criaturas (starbuncles, drygmys, whirlisprigs).", "ars_nouveau:purple_archwood_sapling", "2DFD01E33932BE0C", "04FD37EC71D8D336", "xp"]
