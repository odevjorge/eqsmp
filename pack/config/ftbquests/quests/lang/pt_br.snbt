	quest.24DAE300D62ABE80.quest_desc: ["O altar das runas é onde a mana toma forma elemental. Aqui se forjam runas de água, fogo, terra e ar.", "", "Pra montá-lo, você vai precisar de um §dNúcleo Cinético§r — sem o domínio do movimento, as runas não se fixam.", "botania:runic_altar", "24DAE300D62ABE80", "0489B5E50D7780F6", "xp"]
