	quest.61D5630307136C4C.title: "Blaze Burner"
	quest.61FE4A1A091F8893.quest_desc: ["O §eNúcleo Cinético§r também é sacrificado aqui — o movimento domado do Create entra na soma final.", "", "Três núcleos, três mods, uma só obra-prima."]
	quest.61FE4A1A091F8893.title: "Núcleo Cinético (F2)"
	quest.62148A6DDE69428E.quest_desc: ["Pure daisy converte cobblestone em §alivingrock§r e log em §alivingwood§r ao seu redor (lento). 4 pétalas white no apothecary → 1 pure_daisy.", "botania:pure_daisy", "62148A6DDE69428E", "590494F423C2EFAB", "xp"]
