	quest.447384705C535937.quest_desc: ["Esquema e Pena seleciona área (2 cliques shift+direito) e salva como esquema pra reuso. Combina com esquemaannon pra mass construção.", "create:schematic_and_quill", "447384705C535937", "434BDD45C2930C5A", "xp"]
