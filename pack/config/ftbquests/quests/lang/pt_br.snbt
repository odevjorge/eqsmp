	quest.44C263A885C4364B.quest_desc: ["Adiciona uma grade de §ecrafting§r dentro da própria mochila.", "§7•§r Crafte usando os itens guardados, sem precisar de bancada.", "Combine com Compactação e você vira uma fábrica andante."]
