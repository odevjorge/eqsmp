	quest.6451E6E385BCF00A.title: "Otherstone"
	quest.64D174A7341C9E7E.quest_desc: ["Spawn em biomas nevados. Convoca skeletons.", "", "§eRecompensa:§r 40 níveis de XP + essência elementar"]
	quest.64D174A7341C9E7E.quest_subtitle: "Necromante de Gelo"
	quest.64D174A7341C9E7E.title: "Derrote o Lich (BOMD)"
	quest.64DFAC011ACBEF7D.quest_desc: ["O pool é o coração da Botania — onde toda mana se acumula.", "", "Aqui não se faz com livingrock comum: a fórmula pede §6otherstone§r, aquela pedra que os ocultistas fabricam com fogo espiritual. Sem passar pelo caminho do Ocultismo, o Druida não enche seu pool."]
