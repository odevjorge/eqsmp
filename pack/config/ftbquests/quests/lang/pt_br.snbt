	quest.6524175367DB0A6F.quest_desc: ["Terrasteel helmet: 5× terrasteel_ingot. Parte do conjunto de armadura Gaia.", "botania:terrasteel_helmet", "6524175367DB0A6F", "293CDB12A52ACA61", "xp"]
