	quest.18D3E4535B857760.title: "Dragon Familiar"
	quest.1922B0380E2A5219.quest_desc: ["A §ePlaca de Túmulo§r identifica e decora a sepultura, marcando de quem é aquele descanso.", "", "§7•§r Útil para diferenciar túmulos em servidor com vários jogadores.", "§7•§r Também serve de enfeite memorial num cemitério caseiro."]
	quest.1922B0380E2A5219.quest_subtitle: "Identifica a sepultura"
	quest.1922B0380E2A5219.title: "Placa de Túmulo"
