	quest.3DA8B7FDC6F4365D.quest_desc: ["Steam engine + multi-block boiler com water + calor. Fonte de rotação intermediária — 256+ SU stress capacity.", "create:steam_engine", "3DA8B7FDC6F4365D", "6A77711D3E81DE0E", "xp"]
