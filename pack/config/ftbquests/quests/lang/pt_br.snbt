	quest.139D02C0B765CB8B.quest_desc: ["Chalk white pura: 4 purified_ink + 1 stick. Pentacles mais precisos = chance maior de ritual sucesso.", "occultism:chalk_white", "139D02C0B765CB8B", "41A82B4ED5C7135C", "xp"]
