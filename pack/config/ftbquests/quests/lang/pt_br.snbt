	quest.64F6A72C51CC2190.quest_desc: ["Plante datura_seeds em terra arada. Madura cai 1-2 datura. Datura é o reagente de ash e várias receitas Occultism.", "occultism:datura", "64F6A72C51CC2190", "31AC5E63EEBF988B", "xp"]
