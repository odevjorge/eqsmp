	quest.64F6A72C51CC2190.quest_desc: ["Plant datura_seeds on tilled soil. When mature it drops 1-2 datura. Datura is the reagent for ash and several Occultism recipes.", "occultism:datura", "64F6A72C51CC2190", "31AC5E63EEBF988B", "xp"]
