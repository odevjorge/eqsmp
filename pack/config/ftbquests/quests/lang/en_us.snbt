	quest.49B257A4E8CE4D88.quest_desc: ["Take the §dWitness Amulet§r and open the four paths.", "", "§aNorth:§r §6Engineer§r — mastery of rotation and mechanical force", "§aSouth:§r §2Druid§r — communion with living mana", "§aEast:§r §bArcanist§r — weaving of spells and source", "§aWest:§r §5Occultist§r — pacts with spirits", "", "Each path has its own chapter. This is just the map.", "", "Whoever masters all four may attempt the §dPhilosopher's Stone§r — the absolute end."]
	quest.49B257A4E8CE4D88.quest_subtitle: "The 4 Paths open up"
	quest.49B257A4E8CE4D88.title: "The Witness Amulet"
	quest.49F3F5A01C6EADA5.quest_desc: ["§4The Dead King§r — final boss of Iron's Spells, in the #forge:bosses tag.", "", "Manual summon via the §6Dead King Corpse§r ritual. Endgame drops.", "", "§eReward:§r 100 XP + Legendary Spell Book"]
