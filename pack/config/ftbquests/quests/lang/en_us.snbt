	quest.49838931EDC302C4.quest_desc: ["Small cogwheel: 1 shaft + planks. Lets you transfer rotation at a right angle. Adjacent cogs spin together (just not on the same face).", "create:cogwheel", "49838931EDC302C4", "7C0D9B8DF841D81E", "xp"]
