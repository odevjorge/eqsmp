	quest.2E260FC5FFEB8CCF.quest_desc: ["The §ePortstone§r is a §6private§r teleport receiver.", "", "§7•§r Unlike the waystone, it §cdoes not appear§r in the global destination list.", "§7•§r Use it to create personal, discreet points, accessible only via bound scrolls."]
	quest.2E260FC5FFEB8CCF.title: "Portstone"
	quest.2E5C33EA9550EA9B.quest_desc: ["Marid book: afrit ritual + iesnium_ingot + nether_star. Marid are the most powerful spirits.", "occultism:book_of_binding_marid", "2E5C33EA9550EA9B", "25C8C9783A432005", "xp"]
