	quest.249B0D60EA056C60.quest_desc: ["Botania endgame. Summon with 4 pylons + beacon + gaia spirit. A magic-tier boss.", "", "§eReward:§r 40 XP levels + boss trophy"]
	quest.249B0D60EA056C60.quest_subtitle: "Sentinel of paradise"
	quest.249B0D60EA056C60.title: "Tier 3: Gaia Guardian"
	quest.24DAE300D62ABE80.quest_desc: ["The runic altar is where mana takes elemental form. Here you forge runes of water, fire, earth and air.", "", "To build it you'll need a §dKinetic Core§r — without mastery over motion, the runes won't set.", "botania:runic_altar", "24DAE300D62ABE80", "0489B5E50D7780F6", "xp"]
	quest.24DAE300D62ABE80.quest_subtitle: "Cross-mod F2 — Kinetic Core gate"
	quest.24DAE300D62ABE80.title: "Runic Altar"
	quest.24DE329035C33FC4.quest_desc: ["The §eBakeware§r is the tool for §6baked goods§r.", "", "Breads, pies and cakes need it in the recipe.", "Combine dough and filling for hearty desserts and treats."]
	quest.24DE329035C33FC4.quest_subtitle: "Baked goods"
	quest.24DE329035C33FC4.title: "Bakeware"
	quest.2527AE7D99870E96.quest_desc: ["Book of binding afrit: book_of_binding_empty + 4 red_dye + 1 nether_star. Occultism's highest tier — afrit servants.", "occultism:book_of_binding_afrit", "2527AE7D99870E96", "120A95117AD8F832", "xp"]
