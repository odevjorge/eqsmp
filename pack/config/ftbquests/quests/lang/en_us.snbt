	quest.41306443024F309E.quest_desc: ["Botania's §aRunic Altar§r is now within your reach — the §eKinetic Core§r opened this path.", "", "It's where mana takes runic form, the starting point of the next phase: the §aPure Mana Crystal§r."]
	quest.41306443024F309E.title: "Runic Altar Unlocked"
	quest.420FF5CF6EE201F7.quest_desc: ["Fluid pipes move liquids between tanks, basins, and machines. They connect automatically over up to 16 blocks. Combine with a mechanical_pump for pressure.", "create:fluid_pipe", "420FF5CF6EE201F7", "01666F298F0D2533", "xp"]
