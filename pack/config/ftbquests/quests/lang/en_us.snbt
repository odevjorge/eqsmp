	quest.434EEEFE84713EF0.title: "Magebloom Seed"
	quest.43E7D757BA81444E.quest_desc: ["§eLocks§r the drawer's contents to the current item type.", "§7•§r Even when empty, the drawer stays reserved for that item.", "Keeps you from storing the wrong thing by mistake."]
