	quest.43E7D757BA81444E.title: "Drawer Key"
	quest.444F6806A0BEDC66.quest_desc: ["Here the recipe takes another path: 4 glass + 1 §dmana pearl§r + 1 source_gem + 4 archwood_planks → source_jar.", "", "The source jar stores up to 10000 mana. The imbuement_chamber and ritual_brazier draw directly from nearby jars.", "ars_nouveau:source_jar", "444F6806A0BEDC66", "2FBD4D7173C34A8E", "xp"]
