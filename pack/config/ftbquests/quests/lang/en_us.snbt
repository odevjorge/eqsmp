	quest.474315E7D9EFF270.quest_desc: ["The Warp Scroll saves a location, then teleports you there on use. Critical for base routes.", "ars_nouveau:warp_scroll", "474315E7D9EFF270", "709C0F2ABB4F029B", "xp"]
