	quest.6C0DB05FCAE3195A.title: "Pure Mana Crystal (F3)"
	quest.6C97705F60E37F1C.quest_desc: ["Arcane pedestal: 4 archwood + 4 source_gem. Combine it with the imbuement_chamber for multiple inputs.", "ars_nouveau:arcane_pedestal", "6C97705F60E37F1C", "32F72E5039DDF918", "xp"]
