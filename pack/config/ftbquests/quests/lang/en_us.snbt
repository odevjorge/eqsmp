	quest.3034F34D9C9F2239.quest_desc: ["The iesnium pickaxe is the Occultist's advanced tool. It mines iesnium ore (invisible to common pickaxes) and opens the path to the marid tier.", "", "Marid are the most powerful spirits — whoever reaches here has mastered the whole of occultism.", "occultism:iesnium_pickaxe", "3034F34D9C9F2239", "7FECB42575F48CEF", "xp"]
