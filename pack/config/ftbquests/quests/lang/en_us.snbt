	quest.2E13E3C7C6A5C426.quest_desc: ["Archmage book: 10 spells, 10 glyphs each. Craft it at the apparatus with apprentice_book + 8 source_gem_block + 1 alfsteel.", "ars_nouveau:archmage_spell_book", "2E13E3C7C6A5C426", "357ACE30E745E88C", "xp"]
