	quest.4D05093A5E0FB936.quest_desc: ["You've completed the EQSMP Engineer's path! You've mastered rotation, transmission, processing, fluids, automation and requirements.", "", "Next steps:", "§71)§r Botania Path §a→§r Mana and living flora (dedicated chapter)", "§72)§r Ars Nouveau Path §a→§r Spells and source (dedicated chapter)", "§73)§r Occultism Path §a→§r Spirits and rituals (dedicated chapter)", "§74)§r Philosopher's Stone §a→§r The absolute endgame", "create:large_cogwheel", "4D05093A5E0FB936", "63EB8E3A3FABC229", "xp", "58F29FAC2679F076", "xp_levels", "1A2B3C4D5E6F012B", "1A2B3C4D5E6F0001", "random", "gear", "You have mastered the Engineer", "1AEA877D1497E6CA", "checkmark"]
