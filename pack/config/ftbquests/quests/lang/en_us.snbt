	quest.41034FD47BABE6A8.title: "Fresh Milk"
	quest.4123C1F1910C5929.quest_desc: ["Here the recipe takes another route: 2× manasteel + 2× wheat + 1× §dPure Mana Crystal§r (Pure Mana Crystal) → 1 rune_earth.", "botania:rune_earth", "4123C1F1910C5929", "35BD969BF64415B6", "xp"]
