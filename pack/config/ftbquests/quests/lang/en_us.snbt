	quest.27BEA17571985C02.title: "Pattern Provider"
	quest.27C507EB27CA7200.quest_desc: ["The Occultist knew the secret did not belong to this &dmaterial plane&r. Through &4forbidden&r rituals and guided by the &dThird Eye&r, he sought shortcuts in the shadows, bargaining with &7Djinn&r and &6Afrits.&r His ambition was not to create the Stone, but to trade for it; he prepared the supreme ritual, offering the stability of his own dimension in exchange for the artifact, whispering to entities that &cshould never be heard&r."]
	quest.27C507EB27CA7200.quest_subtitle: "The Pursuit"
	quest.27C507EB27CA7200.title: "The Occultist (Occultism)"
	quest.28F9E30A0166A38F.quest_desc: ["Prepare §e64§r dishes from §ePam's§r. You've mastered Pam's kitchen!", "pamhc2foodextended:bbqchickenpizzaitem", "28F9E30A0166A38F", "09E71089EDE1AFB9", "xp_levels"]
	quest.28F9E30A0166A38F.quest_subtitle: "§6The pinnacle of cooking§r"
	quest.28F9E30A0166A38F.title: "Master Chef"
	quest.29490E0EC3DD58E9.quest_desc: ["The pylon speeds up the flow of mana around the pool — placing four pylons around it makes your botanical machines double their pace.", "", "The recipe here includes a §dsource gem§r from the Arcanists — because the pylon channels magical mana and source at the same time."]
	quest.29490E0EC3DD58E9.quest_subtitle: "Speeds up the pool"
	quest.29490E0EC3DD58E9.title: "Mana Pylon"
	quest.29BC341B1EBC00EF.quest_desc: ["The §eTome of Soulbound§r keeps your items §bwith you§r even when you die.", "", "§7•§r Apply the bind to the gear you can't afford to lose.", "§7•§r A §6high-value§r item: it's the ultimate insurance against losing your inventory."]
	quest.29BC341B1EBC00EF.quest_subtitle: "Items don't vanish on death"
	quest.29BC341B1EBC00EF.title: "Tome of Soulbound"
	quest.2A5D1F736D073040.quest_subtitle: "Autocraft II"
	quest.2A5D1F736D073040.title: "Molecular Assembler"
	quest.2A7D620BAE54E3A4.quest_desc: ["datura_seeds NO longer drop from grass/tall_grass.", "", "§eOnly way:§r petal_apothecary (Botania) with 2 white_petal + 2 purple_petal + 1 black_petal + seed_reagent → 1 datura_seeds.", "occultism:datura_seeds", "2A7D620BAE54E3A4", "6D04F627E67EF75D", "xp"]
	quest.2A7D620BAE54E3A4.quest_subtitle: "Cross-mod — only via apothecary"
	quest.2A7D620BAE54E3A4.title: "Datura Seeds"
	quest.2A7F0C13B5E64D88.quest_desc: ["The Goddess weighs every death on an &dinvisible scale&r.", "", "Taking the life of &apeaceful or neutral&r creatures — the innocent — is a &csin&r: the world grows &charder&r (Scaling Health difficulty rises).", "", "Slaying &chostile monsters&r is &epenance&r: the difficulty &aeases&r a little.", "", "Deaths in a row build &6momentum&r — a trail of sins weighs heavier and heavier, and a steady hunt of monsters calms the world little by little."]
	quest.2A7F0C13B5E64D88.title: "The Goddess's Scales"
	quest.2A820CCBE2001574.quest_desc: ["Empty soul gem: ritual with chalk purple + book_of_binding_djinni + 4 spirit_attuned_gem. Used to capture entities.", "occultism:soul_gem", "2A820CCBE2001574", "2B678C0EC00FFBAA", "xp"]
	quest.2A820CCBE2001574.quest_subtitle: "Captures spirits"
	quest.2A820CCBE2001574.title: "Empty Soul Gem"
	quest.2AB9B99A6CD15CA0.quest_desc: ["The volcanic link generates mana from nearby lava blocks. Place it in the nether or a home with a lava lake.", "ars_nouveau:volcanic_sourcelink", "2AB9B99A6CD15CA0", "0D90FE79AA3FAE22", "xp"]
	quest.2AB9B99A6CD15CA0.quest_subtitle: "Link via lava"
	quest.2AB9B99A6CD15CA0.title: "Source Link Volcanic"
	quest.2AC78DAF3187BB63.quest_desc: ["Chalk purple impure: 3 white_chalk + 1 spirit_attuned_gem + 1 purple_dye + 1 ink_sac. For djinni rituals.", "occultism:chalk_purple_impure", "2AC78DAF3187BB63", "3377845828696EDA", "xp"]
