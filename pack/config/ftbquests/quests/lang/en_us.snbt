	quest.2C39178B382722A8.quest_desc: ["The first-phase §eMagical Agglutinate§r returns — and this time it will be consumed for good.", "", "It hands the final core the original link that united Create, Botania and Occultism."]
	quest.2C39178B382722A8.title: "Magical Agglutinate (F1)"
