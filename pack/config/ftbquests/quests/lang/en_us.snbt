	quest.254D07FA5FF91291.quest_subtitle: "Ancient dragon"
	quest.254D07FA5FF91291.title: "Tier 7: Ancient Remnant"
	quest.25BCD2C65E508DF4.quest_subtitle: "More space"
	quest.25BCD2C65E508DF4.title: "64k Item Storage Cell"
	quest.262D36427FE3C7C8.quest_desc: ["The §6Andesite Casing§r opens Create's basic tier — simple but necessary machines to start automating.", "", "Craft each of them to complete the step.", "", "§7Windmill Bearing · Mechanical Bearing · Deployer · Mechanical Drill · Mechanical Saw · Encased Fan"]
	quest.262D36427FE3C7C8.quest_subtitle: "Engineering essentials"
	quest.262D36427FE3C7C8.title: "Andesite Machines"
	quest.266731209DF722B9.quest_desc: ["The Ring of Loki lets you place blocks in a pattern (up to 9x9). Paired with a full chest, mass building.", "botania:loki_ring", "266731209DF722B9", "7FE0B9576E3E5ACD", "xp"]
	quest.266731209DF722B9.quest_subtitle: "Multi-block placement"
	quest.266731209DF722B9.title: "Ring of Loki"
	quest.269FBEBC697DE917.quest_desc: ["Chalk white impure: 4 bone_meal + 1 stick. Imprecise but works for your first rituals.", "occultism:chalk_white_impure", "269FBEBC697DE917", "2791E6EA818D12C0", "xp"]
