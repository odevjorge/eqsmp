	quest.00A295065AD2C817.quest_desc: ["Spawns in Mushroom Islands. Spores and tentacles.", "", "§eReward:§r 40 XP levels + elemental essence"]
	quest.00A295065AD2C817.quest_subtitle: "Flower of the Void"
	quest.00A295065AD2C817.title: "Slay Void Blossom"
	quest.00A4B34EE77FF30A.quest_desc: ["§bSource Gem§r is crystallized Source, produced in the §bImbuement Chamber§r.", "", "Pure magical energy from Ars Nouveau — the reagent that stabilizes the mana crystal."]
	quest.00A4B34EE77FF30A.title: "Source Gem"
	quest.00CF092C304CB005.quest_desc: ["Grab the Worn Notebook (1 book + 1 sapling in a crafting grid). This is your in-game guide to Ars Nouveau — glyphs, creatures, rituals.", "ars_nouveau:worn_notebook", "00CF092C304CB005", "29269E80FBEA97F9", "xp"]
	quest.00CF092C304CB005.quest_subtitle: "The Arcanist's notebook"
	quest.00CF092C304CB005.title: "Worn Notebook"
	quest.014032E40C374349.quest_desc: ["The manasteel pickaxe consumes mana instead of durability. Paired with a mana_ring in its slot, your tools last almost forever.", "botania:manasteel_pick", "014032E40C374349", "7AAC45124B9DCC11", "xp"]
	quest.014032E40C374349.quest_subtitle: "Pickaxe that consumes mana"
	quest.014032E40C374349.title: "Manasteel Pickaxe"
	quest.0150F38BD9453295.quest_desc: ["A souped-up shulker box: §eportable§r and it accepts upgrades.", "§7•§r Carry the contents with you and still use pickup or filters inside it.", "Combines the best of the shulker with the Sophisticated system."]
	quest.0150F38BD9453295.quest_subtitle: "Portable and upgradable"
	quest.0150F38BD9453295.title: "Copper Shulker"
	quest.01691F992F578B48.quest_desc: ["The §6Deployer§r applies items and tools onto whatever sits on the §6Depot§r, step by step.", "", "Here it will combine the §eAgglutinate§r, §eKinetic Core§r and §ePure Mana Crystal§r in a precise sequence."]
	quest.01691F992F578B48.title: "Deployer"
	quest.016B4C4A9E9F5AC5.quest_desc: ["The narslimmus kills slimes (needs slime chunks or a farm). Mana is proportional to the slime's size.", "botania:narslimmus", "016B4C4A9E9F5AC5", "0D4E0326EE9B2C6A", "xp"]
	quest.016B4C4A9E9F5AC5.quest_subtitle: "Slime-powered generator"
	quest.016B4C4A9E9F5AC5.title: "Narslimmus"
	quest.016C26968B073CC3.quest_desc: ["Huge capacity and many §eupgrade§r slots at once.", "§7•§r Here you can stack pickup, magnet, smelting and more without running out of room.", "The leap that turns the backpack into a walking logistics system."]
	quest.016C26968B073CC3.title: "Diamond Backpack"
	quest.0170FF9ED91E59CB.quest_subtitle: "Network battery"
	quest.0170FF9ED91E59CB.title: "Energy Cell"
	quest.0179046F142675BC.quest_desc: ["The most important item: §akeeps your items§r when you die.", "tombstone:ankh_of_prayer", "0179046F142675BC", "50FAEED34A072C9F", "xp_levels"]
	quest.0179046F142675BC.quest_subtitle: "Keeps your inventory on death!"
	quest.0179046F142675BC.title: "Ankh of Prayer"
	quest.0199BA6195EA5EC8.quest_desc: ["The 3 §ePresses§r (Calculation, Engineering, Logic) come from meteorites.", "They're not consumed — they're permanent molds."]
	quest.0199BA6195EA5EC8.quest_subtitle: "Meteorite treasure"
	quest.0199BA6195EA5EC8.title: "Processor Presses"
	quest.01E4D228A52B8536.quest_desc: ["The steam engine is the veteran Engineer's heart. Connected to a boiler, it generates more force than any water wheel or windmill.", "", "Whoever reaches here has mastered rotation, heat and fluid."]
	quest.01E4D228A52B8536.quest_subtitle: "Advanced Create"
	quest.01E4D228A52B8536.title: "Steam Engine"
	quest.01FA587EAAECBC0B.quest_desc: ["§eExtends the reach§r of the Drawer Controller to more distant drawers.", "§7•§r Place it along the way to connect far-off groups of drawers.", "Allows larger warehouses without losing the central access point."]
	quest.01FA587EAAECBC0B.quest_subtitle: "Extends the controller's reach"
	quest.01FA587EAAECBC0B.title: "Controller Slave"
	quest.023FAE93A2B61CAC.quest_desc: ["Cataclysm. Sunken City. Possibly the hardest in the mod.", "", "§eReward:§r 120 XP levels + drop"]
	quest.023FAE93A2B61CAC.quest_subtitle: "Abyssal Terror"
	quest.023FAE93A2B61CAC.title: "Side: The Leviathan"
	quest.02F32BCF59D476D5.quest_desc: ["Connects all nearby drawers into a §ecentral§r access point.", "§7•§r Insert items through the controller and they go to the right drawer on their own.", "Take and store without running from drawer to drawer."]
	quest.02F32BCF59D476D5.quest_subtitle: "Central access to drawers"
	quest.02F32BCF59D476D5.title: "Drawer Controller"
	quest.0337B201C5266C96.quest_desc: ["The source relay collector centralizes mana from multiple source_jars/relays into 1 point. Useful in large factories.", "ars_nouveau:relay_collector", "0337B201C5266C96", "3618C233BE545DBF", "xp"]
