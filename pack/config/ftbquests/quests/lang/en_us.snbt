	quest.03AA604EB1F693D2.quest_desc: ["Here the recipe takes a different path: book_of_binding_empty + 4 white_dye + 1 §dMagical Agglutinate§r (Magical Agglutinate) → book_of_binding_foliot.", "", "Without the Agglutinate, you don't unlock the foliot — the cheapest tier of spirits.", "occultism:book_of_binding_foliot", "03AA604EB1F693D2", "0AEB53137AB0C1D8", "xp"]
	quest.03AA604EB1F693D2.quest_subtitle: "F1 Requirement — Magical Agglutinate"
