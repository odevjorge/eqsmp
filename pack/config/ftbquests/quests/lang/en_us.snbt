	quest.2527AE7D99870E96.title: "Book of Binding (Afrit)"
	quest.253C4CA48256ACB6.quest_desc: ["A drawer with §e2 slots§r, each holding one type of item in large quantity.", "§7•§r Click to insert, click again to take out a single unit.", "The foundation of visual organization with Storage Drawers."]
	quest.253C4CA48256ACB6.title: "Drawer (2 slots)"
