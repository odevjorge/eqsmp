	quest.66082991AED39DA0.quest_desc: ["§7EQSMP Spiritual Core reminder:§r the ars_nouveau:ritual_brazier (Ars) uses the §dSpiritual Core§r in its craft.", "", "The brazier connects Ars + Occultism via rituals. Advanced ritual gear.", "ars_nouveau:ritual_brazier", "66082991AED39DA0", "53AF58866555EA8B", "xp"]
