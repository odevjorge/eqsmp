	quest.52E5589B3A1C1B8D.quest_subtitle: "Divine material"
	quest.52E5589B3A1C1B8D.title: "Gaia Ingot"
	quest.52EFDAA1F5F00F89.quest_desc: ["Whirlisprig charm: grows plants/crops in an area. Drops items as they grow. An intermediate farm.", "ars_nouveau:whirlisprig_charm", "52EFDAA1F5F00F89", "3987D726F12E9B14", "xp"]
	quest.52EFDAA1F5F00F89.quest_subtitle: "Farming familiar"
	quest.52EFDAA1F5F00F89.title: "Whirlisprig"
	quest.5308482D02A79856.quest_desc: ["Activate a §eWaystone§r to create fast-travel points.", "waystones:waystone", "5308482D02A79856", "62719E91FA39081C", "xp_levels", "1A2B3C4D5E6F0134", "1A2B3C4D5E6F0001", "random", "§2Teleport network§r", "5AA2BC1F13A53E47", "waystones:waystone", "item"]
	quest.5308482D02A79856.quest_subtitle: "§2Teleport network§r"
	quest.5308482D02A79856.title: "Waystone"
	quest.5309AB20B43F9D7A.quest_desc: ["Copper casing requires a mechanical_press to forge copper_sheets. For everything fluid: hose pulley, spout, smart pipes.", "create:copper_casing", "5309AB20B43F9D7A", "01B43F0538AD4384", "xp"]
	quest.5309AB20B43F9D7A.quest_subtitle: "Fluid-tier casing"
	quest.5309AB20B43F9D7A.title: "Copper Casing"
	quest.530E5A90C40E638B.quest_subtitle: "§2Extra pockets§r"
	quest.530E5A90C40E638B.title: "Backpack"
	quest.53C02F9EA32FB8B2.quest_desc: ["The §eMossy Waystone§r is a §baesthetic§r variant of the waystone.", "", "§7•§r Activate it and it joins your §6teleport§r network between waystones.", "§7•§r Same function as the regular waystone, with a moss-covered look."]
	quest.53C02F9EA32FB8B2.quest_subtitle: "Variant"
	quest.53C02F9EA32FB8B2.title: "Mossy Waystone"
	quest.54C42AF051BF0447.quest_desc: ["§4Sourceberry Bushes no longer spawn in Taiga/Archwood.§r", "", "Apothecary recipe: §c3 blue petals + 1 vanilla sweet_berry§r → 1 sourceberry_bush.", "", "Plant the bush on farmland/grass. When ripe (age 3), break it with Fortune:", "• §a1-3× source_berry§r (fruit)", "• §e1-2× sourceberry_bush§r (renewal)", "", "You'll need a lot of berries — each cursed_aglutinado takes several."]
	quest.54C42AF051BF0447.quest_subtitle: "Sole source of the bush"
	quest.54C42AF051BF0447.title: "Sourceberry Bush via Apothecary"
	quest.54C84C7BE1EA8903.quest_desc: ["The apparatus is the veteran Arcanist's crafting core. Tomes, parchments, advanced items — everything is born here.", "", "To build it, you need a §dKinetic Core§r — mechanics and magic meet at this point."]
	quest.54C84C7BE1EA8903.quest_subtitle: "Arcane crafting"
	quest.54C84C7BE1EA8903.title: "Enchanting Apparatus"
	quest.55402C0A1C5787CE.quest_desc: ["The strongest material Botania can offer. Forged on the Terra Plate, consuming half a million mana.", "", "It's the base of the §dSpiritual Core§r — the fourth and last of the magical pillars."]
	quest.55402C0A1C5787CE.quest_subtitle: "Advanced Botania"
	quest.55402C0A1C5787CE.title: "Terrasteel Ingot"
	quest.554C866E6CB5D435.quest_desc: ["The hourglass emits redstone at configurable intervals. Useful for automation timing.", "botania:hourglass", "554C866E6CB5D435", "4A77A51FE0E4D731", "xp"]
	quest.554C866E6CB5D435.quest_subtitle: "Redstone timer"
	quest.554C866E6CB5D435.title: "Hovering Hourglass"
	quest.557FD4F4FF84E22F.quest_desc: ["Golden bowl: 1 sacrificial_bowl + 4 gold_ingot. Ritual ACTIVATION — drop the ritual_dummy here.", "occultism:golden_sacrificial_bowl", "557FD4F4FF84E22F", "2F573398562BDCEF", "xp"]
	quest.557FD4F4FF84E22F.quest_subtitle: "Main receptacle"
	quest.557FD4F4FF84E22F.title: "Golden Sacrificial Bowl"
	quest.55B8D9B751219B21.quest_desc: ["Blaze cake (cake base + cinder flour + sugar via mixer) is supercharged fuel for the blaze burner. Required for superheated recipes (steel alloy etc).", "create:blaze_cake", "55B8D9B751219B21", "19CB4C7FA4A925FB", "xp"]
	quest.55B8D9B751219B21.quest_subtitle: "Superheated fuel"
	quest.55B8D9B751219B21.title: "Blaze Cake"
	quest.55C96D5F62390579.quest_subtitle: "Blue spark"
	quest.55C96D5F62390579.title: "Charged Certus"
	quest.55E29A800F32673B.quest_desc: ["Prepare §e16§r basic foods.", "pamhc2foodcore:potroastitem", "55E29A800F32673B", "27D85036C5B0C2F4", "xp_levels"]
	quest.55E29A800F32673B.quest_subtitle: "Basic dishes"
	quest.55E29A800F32673B.title: "Basic Cooking"
	quest.55E621C067F20416.quest_desc: ["There are andesite_casing, brass_casing, copper_casing, railway_casing. Craft at least 1 of each — requirements from different tiers.", "create:brass_casing", "55E621C067F20416", "2465A93957C080FD", "xp"]
	quest.55E621C067F20416.quest_subtitle: "Casing collection"
	quest.55E621C067F20416.title: "Casing Variants"
	quest.5624CD07174A4AD7.quest_desc: ["The §eReturn Scroll§r takes you back to the §6nearest waystone§r.", "", "§7•§r It is §cconsumable§r: each use spends one scroll.", "§7•§r Ideal as a quick trip home after an expedition."]
	quest.5624CD07174A4AD7.quest_subtitle: "Returns to the nearest waystone"
	quest.5624CD07174A4AD7.title: "Return Scroll"
	quest.5628AFF5CD1C074A.quest_desc: ["§7Occultism recipe:§r 1 cobblestone tossed into spirit_fire → 1 otherstone.", "", "Otherstone is §erequired§r to craft EQSMP's mana_pool and diluted_pool (Botania).", "occultism:otherstone", "5628AFF5CD1C074A", "2F2A860081F0B328", "xp"]
	quest.5628AFF5CD1C074A.quest_subtitle: "Botania ↔ Occultism requirement"
	quest.5628AFF5CD1C074A.title: "Otherstone (F1 Requirement)"
	quest.566B77BE2238F816.quest_desc: ["Belts connect 2 shafts at any angle (up to 90°). They carry items AND entities. 2 leather + andesite_alloy + dried kelp string → 3 belts.", "create:belt_connector", "566B77BE2238F816", "26C59893CAE034E7", "xp"]
	quest.566B77BE2238F816.quest_subtitle: "Basic logistics"
	quest.566B77BE2238F816.title: "Belt"
	quest.569BD9E9F727948B.quest_desc: ["Void elemental boss. Spawns in the End.", "", "§eReward:§r 55 XP levels + drop"]
	quest.569BD9E9F727948B.quest_subtitle: "Pillar of the Void"
	quest.569BD9E9F727948B.title: "Side: BOMD Obsidilith"
	quest.56A6E32CF531C609.quest_desc: ["§ePure Mana Crystal§r — the milestone of this phase. The §bImbuement Chamber§r and the §bSource Gem§r refine the §ccorrupted crystal§r into a stable jewel.", "", "Botania's mana and Ars's Source united. It unlocks §dOccultism§r and Create's §6Mechanical Arm§r."]
	quest.56A6E32CF531C609.title: "The Pure Mana Crystal"
	quest.56AA6C6657EC35A0.quest_subtitle: "Energy insulator"
	quest.56AA6C6657EC35A0.title: "Quartz Fiber"
	quest.56C829025A2869AE.quest_desc: ["A giant Nether bastion dweller. Devastating AOE. Watch out for the stomp.", "", "§eReward:§r 40 XP levels + unique drop"]
	quest.56C829025A2869AE.quest_subtitle: "Monstrosity of the Nether"
	quest.56C829025A2869AE.title: "Slay Netherite Monstrosity"
	quest.56DF50D6324509B8.quest_desc: ["§eArs Nouveau in EQSMP has been modified:§r source_gem now comes only via:", "", "§71)§r §dmana_diamond§r (1 diamond + Botania mana_pool) → spirit_fire ritual (Occultism) → 1 source_gem", "§72)§r §dspirit_attuned_crystal§r (Agglutinate cascade → amethyst_block) → imbuement chamber → 4 source_gem", "", "You'll need source_gem for many Ars recipes AND for the Create precision_mechanism requirements).", "ars_nouveau:source_gem", "56DF50D6324509B8", "17CE9F2C5139742E", "xp"]
	quest.56DF50D6324509B8.quest_subtitle: "EQSMP cross-mod — Ars needs you"
	quest.56DF50D6324509B8.title: "Reminder: Source Gem"
	quest.575DE2EDDB612032.quest_desc: ["The §eTome of Magical Impregnation§r raises the §6enchantment level§r and magical knowledge of an item.", "", "§7•§r Pushes enchantments beyond the table's normal limit.", "§7•§r An §6advanced§r resource to supercharge your best gear."]
	quest.575DE2EDDB612032.title: "Tome of Magical Impregnation"
	quest.576EEC7CF3CF20EF.quest_desc: ["Crystal apparatus: afrit ritual + spirit_attuned_crystal + iesnium. Component of the marid miner (advanced mining).", "occultism:iesnium_ingot", "576EEC7CF3CF20EF", "1957882E0F0A678D", "xp"]
	quest.576EEC7CF3CF20EF.quest_subtitle: "Marid stabilizer"
	quest.576EEC7CF3CF20EF.title: "Crystal Apparatus"
	quest.58A260CB8418E4F1.quest_subtitle: "§2Souped-up chests§r"
	quest.58A260CB8418E4F1.title: "Sophisticated Chest"
	quest.5909C601B6A937D1.quest_desc: ["Infused pickaxe: djinni ritual with 1 diamond_pickaxe + 4 spirit_attuned_gem. Sees iesnium_ore (invisible to a normal pickaxe).", "occultism:infused_pickaxe", "5909C601B6A937D1", "6E6D9D3A53A4D303", "xp"]
	quest.5909C601B6A937D1.quest_subtitle: "Pickaxe that sees iesnium"
	quest.5909C601B6A937D1.title: "Infused Pickaxe"
	quest.593F35F2A58DB752.quest_desc: ["High capacity and several §eupgrade§r slots at once.", "§7•§r Ideal for the central warehouse of your base.", "Combine it with the Controller to access everything from a single point."]
	quest.593F35F2A58DB752.title: "Diamond Chest"
	quest.596316A02613FA3F.quest_desc: ["Here the recipe takes another route: 2× manasteel + 2× blaze_powder + 1× §dPure Mana Crystal§r (Pure Mana Crystal) → 1 rune_fire.", "botania:rune_fire", "596316A02613FA3F", "5E8D1F9C46A96FF4", "xp"]
	quest.596316A02613FA3F.quest_subtitle: "Cross-mod F3 — elemental rune"
	quest.596316A02613FA3F.title: "Rune of Fire"
	quest.59A5D0BCF9B9E2D0.quest_desc: ["Storage controller: storage_base + dimensional_matrix + frame. Access an infinite inventory (limited by stabilizers).", "occultism:storage_controller", "59A5D0BCF9B9E2D0", "19EA1A6950C6C64D", "xp"]
	quest.59A5D0BCF9B9E2D0.quest_subtitle: "Complete storage system"
	quest.59A5D0BCF9B9E2D0.title: "Storage Controller"
	quest.5A2AC224F5B13979.quest_desc: ["Occultism's §dSoul Gem§r captures the soul of a living creature — use it on a docile being to seal the spirit into the gem.", "", "This captured soul is the spiritual fuel of the final core."]
	quest.5A2AC224F5B13979.title: "Soul Gem"
	quest.5AA2177BF0CADDE0.quest_desc: ["Ancient Forge in the Nether. Master of flames and Ignitium.", "", "§eReward:§r 50 XP levels + unique drop"]
	quest.5AA2177BF0CADDE0.quest_subtitle: "Lord of the Forges"
	quest.5AA2177BF0CADDE0.title: "Slay Ignis"
	quest.5AD3FE37BF6D66D4.quest_desc: ["The §dTwilight Forest§r is a dimension of eternal twilight, full of ancient creatures and forgotten treasures.", "", "Use the §6Twilight Forest Portal§r (water + 4 flowers in a square, throw in a diamond) to enter.", "", "§7Inside: 6 bosses in progression order."]
	quest.5AD3FE37BF6D66D4.quest_subtitle: "The first step on the adventure"
	quest.5AD3FE37BF6D66D4.title: "Enter the Twilight Forest"
	quest.5AD9297290CBA43C.quest_desc: ["Arranged in a grid, these crafters assemble any complex recipe on their own. It's like having a thousand hands forging in parallel.", "", "You'll need them to forge the §dPrecision Mechanism§r — a critical mid-game Create part.", "create:mechanical_crafter", "5AD9297290CBA43C", "5597EB0AB38205C0", "xp"]
	quest.5AD9297290CBA43C.quest_subtitle: "Advanced automated crafting"
	quest.5AD9297290CBA43C.title: "Mechanical Crafter"
	quest.5B03AB38C3D2DC90.quest_desc: ["A clutch disconnects rotation when it receives redstone — the mechanical equivalent of a switch.", "create:clutch", "5B03AB38C3D2DC90", "15CEC1CFEADCDC83", "xp"]
	quest.5B03AB38C3D2DC90.quest_subtitle: "Toggles on/off via redstone"
	quest.5B03AB38C3D2DC90.title: "Clutch"
	quest.5B23C6C5A77DA674.quest_desc: ["Wilden chain (chimera drop) → enchanted_chain components at the apparatus. Combine with archwood + source for alfsteel.", "ars_nouveau:wilden_horn", "5B23C6C5A77DA674", "1DD3F6E4C5DDDB92", "xp"]
	quest.5B23C6C5A77DA674.quest_subtitle: "Advanced material"
	quest.5B23C6C5A77DA674.title: "Wilden Chain"
	quest.5B64012A0840B461.quest_desc: ["Lich Tower — a tall tower in the middle of the forest. It has 3 phases: shielded, projectile, melee.", "", "§eReward:§r 30 XP levels + boss trophy"]
	quest.5B64012A0840B461.quest_subtitle: "Magister of the dead"
	quest.5B64012A0840B461.title: "Slay the Lich"
	quest.5BA8BE35BC4A3C8A.quest_desc: ["Elven spreader: 4× dreamwood + dragonstone + elementium. 2× normal speed, longer range.", "botania:elven_spreader", "5BA8BE35BC4A3C8A", "20A52D8D89D84EBF", "xp"]
	quest.5BA8BE35BC4A3C8A.quest_subtitle: "Alfheim spreader"
	quest.5BA8BE35BC4A3C8A.title: "Elven Spreader"
	quest.5CC3C7A920431310.quest_desc: ["Obtain a §6scroll_blood§r and activate it to learn spells from this school.", "", "§7Scrolls are generated in structures, bought from wandering traders, or dropped by mages."]
	quest.5CC3C7A920431310.quest_subtitle: "Heartstop, Blood Slash, Acupuncture"
	quest.5CC3C7A920431310.title: "School of Blood"
	quest.5CC77A9041A3A9A6.quest_desc: ["The dandelifeon simulates Conway's Game of Life with cells (cellular_block). Each generation = mana. Complex to set up but absurd density.", "botania:dandelifeon", "5CC77A9041A3A9A6", "73A98EF2980FD2FE", "xp"]
	quest.5CC77A9041A3A9A6.quest_subtitle: "Game of Life mana"
	quest.5CC77A9041A3A9A6.title: "Dandelifeon"
	quest.5D34338946363D24.quest_desc: ["Storage controller base: 1 obsidian + 4 spirit_attuned_gem + 4 redstone. Component of the advanced storage_controller.", "occultism:storage_controller_base", "5D34338946363D24", "09A8A43EC5D7C72D", "xp"]
	quest.5D34338946363D24.quest_subtitle: "Storage base"
	quest.5D34338946363D24.title: "Storage Controller Base"
	quest.5D3D2BBC7209A7C8.quest_desc: ["The §eVoodoo Poppet§r §2protects§r you against a specific type of damage or death.", "", "§7•§r Equip it and it's consumed when it absorbs that danger in your place.", "§7•§r There are variants for fall, fire, drowning and other threats: choose according to the risk."]
	quest.5D3D2BBC7209A7C8.quest_subtitle: "Protection against death"
	quest.5D3D2BBC7209A7C8.title: "Voodoo Poppet"
	quest.5DF5B59BB7DEE26C.quest_desc: ["Here the recipe takes a different path: 1 §damethyst shard§r tossed into spirit_fire → 1 spirit_attuned_gem.", "", "It used to be diamond in vanilla; now it's amethyst_shard (cheaper). The gem is used in colored chalks, spirit_lantern, infused pickaxe.", "occultism:spirit_attuned_gem", "5DF5B59BB7DEE26C", "3F2E63E5363AB221", "xp"]
	quest.5DF5B59BB7DEE26C.quest_subtitle: "Cross-mod — spirit gem"
	quest.5DF5B59BB7DEE26C.title: "Attuned Gem"
	quest.5E11C9C5F7912BED.quest_desc: ["The manasteel sword deals damage similar to diamond. Consumes mana instead of durability.", "botania:manasteel_sword", "5E11C9C5F7912BED", "115F2C1A2C0E2B43", "xp"]
	quest.5E11C9C5F7912BED.quest_subtitle: "Mana sword"
	quest.5E11C9C5F7912BED.title: "Manasteel Sword"
	quest.5E1FA86D744121E2.quest_desc: ["The §eSaucepan§r handles sauces and more delicate dishes.", "", "Ideal for §7•§r reductions, creams and dishes that call for low heat.", "Another utensil that stays with you after cooking."]
	quest.5E1FA86D744121E2.title: "Saucepan"
	quest.5E570F77EB109F10.quest_desc: ["The §eTablet of Recall§r §bteleports§r you straight to your last §6grave§r.", "", "§7•§r Saves your life when you die in a distant or dangerous place.", "§7•§r Combine it with the Grave Key to recover everything in the blink of an eye."]
	quest.5E570F77EB109F10.quest_subtitle: "Teleports to your grave"
	quest.5E570F77EB109F10.title: "Tablet of Recall"
	quest.5EDA4644FC22BCC1.quest_desc: ["The aura ring regenerates ~1 mana/tick passively. Combine it with a greater mana_ring for self-sustaining mana.", "botania:aura_ring", "5EDA4644FC22BCC1", "23E49B359B7E76FB", "xp"]
	quest.5EDA4644FC22BCC1.quest_subtitle: "Generates mana passively"
	quest.5EDA4644FC22BCC1.title: "Ring of Aura"
	quest.5F0EEF797725B751.quest_desc: ["You have completed the EQSMP Arcanist path! You mastered glyphs, familiar automation, rituals and defeated the Wilden Chimera.", "", "§7EQSMP recipes you learned:§r", "§7•§r imbuement_chamber + livingwood (Botania)", "§7•§r source_gem via mana_diamond (mid-Agglutinate Botania+Occultism)", "§7•§r source_gem via spirit_attuned_crystal (Agglutinate cascade)", "§7•§r source_jar + mana_pearl (Botania)", "§7•§r dominion_wand + livingwood_twig (Botania)", "", "Next paths: Occultism, Philosopher's Stone.", "ars_nouveau:wilden_horn", "5F0EEF797725B751", "662324FB251C17AC", "xp", "244C6850D12D3E82", "xp_levels", "1A2B3C4D5E6F0129", "1A2B3C4D5E6F0001", "random", "gear", "You have mastered the Arcanist", "507BDFF84998AAEF", "checkmark"]
	quest.5F0EEF797725B751.quest_subtitle: "You have mastered the Arcanist"
	quest.5F0EEF797725B751.title: "Arcane Mastery"
	quest.5F8C39AE9EE75AE5.quest_desc: ["The wormhole frame connects the storage_actuator to a remote output. Critical for storage anywhere.", "occultism:storage_remote", "5F8C39AE9EE75AE5", "00B444A4618269C5", "xp"]
	quest.5F8C39AE9EE75AE5.quest_subtitle: "Remote storage access"
	quest.5F8C39AE9EE75AE5.title: "Wormhole Frame"
	quest.5FE3E587B6564965.quest_desc: ["§eCornbread§r is a simple, filling baked good.", "", "Use ground corn and the bakeware to prepare it.", "A great hunger source §7•§r to take on journeys."]
	quest.5FE3E587B6564965.title: "Cornbread"
	quest.6070A4C94C4F2242.quest_subtitle: "Network bridge"
	quest.6070A4C94C4F2242.title: "Interface"
	quest.607C4F73A1BEDC7A.quest_desc: ["§eFresh Water§r is the base of almost every liquid recipe in Pam's.", "", "Get it by filling a §7•§r bucket or bottle directly from a water source.", "Always keep some around: soups, doughs and drinks call for it."]
	quest.607C4F73A1BEDC7A.quest_subtitle: "Hydration"
	quest.607C4F73A1BEDC7A.title: "Fresh Water"
	quest.607E53E822CD3AB0.quest_desc: ["Rewritten recipe: §c8 andesite + 1 Magical Agglutinate → 4 andesite_alloy§r.", "", "The vanilla recipes (iron + andesite mixing) were removed. The only preserved alternative is decompacting the andesite_alloy_block."]
	quest.607E53E822CD3AB0.quest_subtitle: "Create unlocked"
	quest.607E53E822CD3AB0.title: "Andesite Alloy via Agglutinate"
	quest.60B38AD0A66B6A9A.quest_desc: ["Create's §6Depot§r is the static surface where items rest to be processed by a §6Deployer§r.", "", "It is the stage for the sequenced assembly that will give birth to the spiritual core."]
	quest.60B38AD0A66B6A9A.title: "Depot"
	quest.60E85A3D245613A5.quest_desc: ["Converts an ordinary drawer into an §eupgraded§r form or a different type.", "§7•§r Use it to migrate old drawers without losing the contents.", "Keeps your items while you swap the block for a better version."]
	quest.60E85A3D245613A5.title: "Conversion Upgrade"
	quest.614B009BBD9EAE92.quest_desc: ["§4Cataclysm§r brings 7 unique bosses scattered across custom structures throughout the world.", "", "Each has its own mechanics and powerful drops. They aren't easy — get ready.", "", "§7Structures generate naturally in specific biomes."]
	quest.614B009BBD9EAE92.quest_subtitle: "Elite dimensional bosses"
	quest.614B009BBD9EAE92.title: "Cataclysm — The Seven Nightmares"
	quest.61C8614113BD83F9.quest_desc: ["At the §aRunic Altar§r you gather §aMana Pearl§r, §aMana Diamond§r and the §eKinetic Core§r, feeding mana until the rune completes.", "", "This is where Botania and Create fuse to generate the next heart."]
	quest.61C8614113BD83F9.title: "Runic Forging"
	quest.61D5630307136C4C.quest_desc: ["A blaze burner accepts various fuels to supply heat to basins, crucibles, etc. Heated vs superheated changes the available recipes (blaze cake = superheated).", "create:blaze_burner", "61D5630307136C4C", "4032BD4534FC1FAE", "xp"]
	quest.61D5630307136C4C.quest_subtitle: "Heat source"
	quest.61D5630307136C4C.title: "Blaze Burner"
	quest.61FE4A1A091F8893.quest_desc: ["The §eKinetic Core§r is also sacrificed here — Create's tamed motion enters the final sum.", "", "Three cores, three mods, one single masterpiece."]
	quest.61FE4A1A091F8893.title: "Kinetic Core (F2)"
	quest.62148A6DDE69428E.quest_desc: ["The pure daisy converts cobblestone into §alivingrock§r and logs into §alivingwood§r around it (slowly). 4 white petals in the apothecary → 1 pure_daisy.", "botania:pure_daisy", "62148A6DDE69428E", "590494F423C2EFAB", "xp"]
	quest.62148A6DDE69428E.quest_subtitle: "Purity converter"
	quest.62148A6DDE69428E.title: "Pure Daisy"
	quest.6274B936460CBB82.quest_desc: ["Ars Nouveau's §bRitual Brazier§r has been unlocked by the §eSpiritual Core§r.", "", "It is the brazier of the most advanced magical rituals — the pinnacle of Source automation."]
	quest.6274B936460CBB82.title: "Ritual Brazier Unlocked"
	quest.62A606CBC3205F0D.quest_desc: ["Craft or obtain the §6Iron Tome§r. Each tier allows §emore inscribed spells§r and §emore powerful casts§r.", "", "§7Crafting: recipe similar to the base spell book, with the ingredient of the corresponding tier."]
	quest.62A606CBC3205F0D.quest_subtitle: "+2 slots"
	quest.62A606CBC3205F0D.title: "Iron Tome"
	quest.62D094B38882810D.quest_desc: ["The core of the ME network. Without it, no digital storage.", "§eMain milestone of the chapter.§r"]
	quest.62D094B38882810D.quest_subtitle: "§2THE NETWORK IS BORN§r"
	quest.62D094B38882810D.title: "ME Controller"
	quest.62DEF4405C883451.quest_subtitle: "Configuring cells"
