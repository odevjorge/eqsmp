	quest.2AC78DAF3187BB63.title: "Chalk Purple (Impure)"
	quest.2B153572BFCC5FCB.quest_desc: ["The §eiron§r step of the storage upgrades, above copper.", "§7•§r Increases even further how many items each drawer slot holds.", "Keep climbing the tiers for absurd capacities."]
	quest.2B153572BFCC5FCB.title: "Storage Upgrade (Iron)"
	quest.2BA3EDABD691146B.quest_desc: ["Summon the Gaia Guardian: gaia_pylon at the center of a 22x22 arena with an active beacon_block (level 3+ pyramid). Throw the dice of fate to begin.", "", "§eReward:§r gaia_ingot (8-12 per kill).", "botania:dice", "2BA3EDABD691146B", "7FBFB6DE8B47B252", "xp"]
	quest.2BA3EDABD691146B.quest_subtitle: "Final boss (Botania)"
	quest.2BA3EDABD691146B.title: "Gaia Guardian"
	quest.2BB41BF9FFF5F2E1.quest_desc: ["Brass casing needs brass_ingot (Create mixing: copper + zinc). It enables more advanced components — configurable funnels, mechanical arm, etc.", "create:brass_casing", "2BB41BF9FFF5F2E1", "75C0D20F54949E4C", "xp"]
	quest.2BB41BF9FFF5F2E1.quest_subtitle: "Intermediate casing"
	quest.2BB41BF9FFF5F2E1.title: "Brass Casing"
	quest.2BDCFE3F41A97BF9.quest_desc: ["Here the recipe takes a different path: 6 iron_nugget + 1 spirit_attuned_gem + 3 §dmanasteel§r → spirit_lantern.", "", "The lantern emits mystical light and blocks creature spawns in a large radius. Cross-mod Botania.", "occultism:spirit_lantern", "2BDCFE3F41A97BF9", "1E56C568184D9A9B", "xp"]
