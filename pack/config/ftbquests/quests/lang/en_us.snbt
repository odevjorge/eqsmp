	quest.652CB209F9C8DF8A.quest_desc: ["The Wilden Chimera is the boss of Ars Nouveau. Summon it with a wilden horn at the ritual brazier.", "", "Rewards: wings for permanent flight, a spike for advanced crafting.", "ars_nouveau:wilden_horn", "652CB209F9C8DF8A", "3AEA35DFB51512A3", "xp"]
