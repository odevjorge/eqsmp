	quest.45FA93D5646B8426.quest_desc: ["The gourmaryllis eats food. The more varied the menu, the more mana — up to ~30 mana/tick at peak. Auto-feed via hopper.", "botania:gourmaryllis", "45FA93D5646B8426", "682423BF74C23A74", "xp"]
