	quest.642032C8973A2BA9.quest_desc: ["Chain drives transfer rotation between parallel shafts up to 3 blocks apart. Good for compact layouts.", "create:encased_chain_drive", "642032C8973A2BA9", "0DEC78EF6ADFE179", "xp"]
