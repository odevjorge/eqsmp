	quest.24390C508A6CA48D.title: "Energy Acceptor"
	quest.248B7F048FDCB864.quest_desc: ["Break + Projectile/Touch breaks blocks remotely. Mining at a distance.", "ars_nouveau:glyph_break", "248B7F048FDCB864", "6F649B7F183A25A3", "xp"]
