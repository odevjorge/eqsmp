	quest.49F3F5A01C6EADA5.title: "Side: The Dead King"
	quest.4AAC1EB471652088.quest_desc: ["The endoflame burns fuels (coal, log, etc) to generate mana. ~3 mana/tick. Petals: 2 brown + 2 red + 1 gray in the apothecary with seed_reagent.", "botania:endoflame", "4AAC1EB471652088", "6C64B0FF93888509", "xp"]
