	quest.04235322CEC85B45.title: "Spatial Pylon"
	quest.045BFA201FD4D70E.quest_desc: ["Mystical flower → 4 petals on the crafting table. Gather at least 4 different colors (white, red, yellow, blue) to get the petal_apothecary going.", "botania:white_petal", "045BFA201FD4D70E", "798B454476B9DA0D", "xp"]
	quest.045BFA201FD4D70E.quest_subtitle: "Craft petals of each color"
	quest.045BFA201FD4D70E.title: "Basic Petals"
	quest.04700A2D6AE62B7C.quest_desc: ["A weighted ejector launches items forward with tunable force. Configurable via wrench (distance) and click (item count filter).", "create:weighted_ejector", "04700A2D6AE62B7C", "72741CE140265BEC", "xp"]
	quest.04700A2D6AE62B7C.quest_subtitle: "Launches items with timing"
	quest.04700A2D6AE62B7C.title: "Weighted Ejector"
	quest.05123EECDFA1C145.quest_desc: ["The thermalily consumes a lava bucket (~30s cooldown). Excellent mana density, but requires lava farms (Create pumping in the nether).", "botania:thermalily", "05123EECDFA1C145", "179D9489A6AA13B2", "xp"]
	quest.05123EECDFA1C145.quest_subtitle: "Lava generator"
	quest.05123EECDFA1C145.title: "Thermalily"
	quest.051334D6FCEF3266.quest_desc: ["A schedule is a document-item. It configures stops, conditions, actions. Place it in a train conductor for autonomy.", "create:schedule", "051334D6FCEF3266", "6CCF4C67B31C3637", "xp"]
	quest.051334D6FCEF3266.quest_subtitle: "Programs trains"
	quest.051334D6FCEF3266.title: "Schedule"
	quest.059452AA483EC0C7.quest_desc: ["Mana lens: 3 livingrock + glass in the right shape. No effect on its own, it's the base for other custom lenses.", "botania:lens_normal", "059452AA483EC0C7", "4275C864DE26748D", "xp"]
	quest.059452AA483EC0C7.quest_subtitle: "Basic spreader modifier"
	quest.059452AA483EC0C7.title: "Mana Lens"
	quest.05CD90901501D6D7.quest_desc: ["The §eBound Scroll§r stays §bfixed§r to a specific waystone of your choice.", "", "§7•§r It always takes you to the same destination, no need to open the list.", "§7•§r Perfect for a direct, constant route to a key point."]
	quest.05CD90901501D6D7.quest_subtitle: "Tied to a fixed waystone"
	quest.05CD90901501D6D7.title: "Bound Scroll"
	quest.07110F7FE64E8F0B.quest_desc: ["The petal apothecary is the central crafting block for functional flowers. Place petals + reagent, then pour a water bucket to activate.", "", "the apothecary is also the only path to make §asourceberry_bush§r and §asem datura_seeds§r (requires Aglutinado).", "botania:apothecary_default", "07110F7FE64E8F0B", "378574305B47C3E3", "xp"]
	quest.07110F7FE64E8F0B.quest_subtitle: "Botanical crafting altar"
	quest.07110F7FE64E8F0B.title: "Petal Apothecary"
	quest.071B21472B9CAFC2.quest_desc: ["The Engineer's path begins here. Create's wrench is your first tool — use it to rotate shafts, adjust machines and dismantle components without losing them.", "", "§eRight-click§r on any Create block to rotate it; §eShift+right-click§r to pick it back up.", "create:wrench", "071B21472B9CAFC2", "2FB6E1EC63D54DCC", "xp"]
	quest.071B21472B9CAFC2.quest_subtitle: "The Engineer's first step"
	quest.071B21472B9CAFC2.title: "The Wrench"
	quest.0748B447D83FF731.quest_subtitle: "Network in your pocket"
	quest.0748B447D83FF731.title: "Wireless Terminal"
	quest.075C12C4CBA2CA8F.quest_desc: ["§4The Dead King§r — the mod's final undead boss. In the §6#forge:bosses§r tag.", "", "Summon: assemble the §6Dead King Corpse§r (item) on a pillar of chiseled stone + ritual.", "", "Drop: enchanted §6legendary spell book§r + eldritch scrolls."]
	quest.075C12C4CBA2CA8F.quest_subtitle: "Iron's Spells final lich"
	quest.075C12C4CBA2CA8F.title: "Boss: The Dead King"
	quest.077FE2E442F3700D.quest_desc: ["The portable fluid interface lets you exchange fluids between a static tank and a moving contraption (train, cart). Advanced mobile factory work.", "create:portable_fluid_interface", "077FE2E442F3700D", "31E57612D8606B10", "xp"]
	quest.077FE2E442F3700D.quest_subtitle: "Fluid transfer via contraption"
	quest.077FE2E442F3700D.title: "Portable Fluid Interface"
	quest.07EDE51D4A681BAF.quest_subtitle: "Large battery"
	quest.07EDE51D4A681BAF.title: "Dense Energy Cell"
	quest.083F375AFD56BB04.quest_subtitle: "Copies config"
	quest.083F375AFD56BB04.title: "Memory Card"
	quest.08D1887C3AB6F872.quest_desc: ["To reach the top processing tier for the Cursed Magical Agglutinate, you need the Integrated Dynamics Squeezer.", "", "Custom recipe: §c4 livingwood_twig + 4 andesite_1x + 1 andesite_2x§r — requires no iron, keeping F1 purely Botania+Create."]
	quest.08D1887C3AB6F872.quest_subtitle: "No iron in the recipe"
	quest.08D1887C3AB6F872.title: "Squeezer (custom recipe)"
	quest.08ECE6DF02FF3BA0.quest_desc: ["Touch triggers the spell when you click a nearby block/entity. Useful for ritualistic spells.", "ars_nouveau:glyph_touch", "08ECE6DF02FF3BA0", "0EDF4A0A60901CE7", "xp"]
	quest.08ECE6DF02FF3BA0.quest_subtitle: "Form — touch"
	quest.08ECE6DF02FF3BA0.title: "Glyph: Touch"
	quest.0925C19C204B0A6D.quest_desc: ["The chamber absorbs source from the jars around it to transform items. Everything on the Arcanist's path passes through here.", "", "Here it includes livingwood in the recipe — because living wood channels source better than any other."]
	quest.0925C19C204B0A6D.quest_subtitle: "Ars hub"
	quest.0925C19C204B0A6D.title: "Imbuement Chamber"
	quest.094FF40CB5BECD86.quest_desc: ["Craft at least one rune of each type (the elemental ones are already covered in earlier quests, but there are zodiac, lust, gluttony runes etc).", "botania:rune_pride", "094FF40CB5BECD86", "52553B948935CBDF", "xp"]
	quest.094FF40CB5BECD86.quest_subtitle: "All Botania runes"
	quest.094FF40CB5BECD86.title: "Rune Collection"
	quest.09C725DAB97F639E.quest_desc: ["Craft or obtain the §6Diamond Tome§r. Each tier allows §emore inscribed spells§r and §emore powerful casts§r.", "", "§7Crafting: recipe similar to the base spell book, with the ingredient of the corresponding tier."]
	quest.09C725DAB97F639E.quest_subtitle: "Endgame craftable"
	quest.09C725DAB97F639E.title: "Diamond Tome"
	quest.09E4E8A133AE1DC2.quest_desc: ["Take your search to the §edesert and savanna§r.", "", "Even in dry lands, heat-resistant §6wild gardens§r appear.", "Break each one §7•§r and discover ingredients that only grow in arid climates."]
	quest.09E4E8A133AE1DC2.title: "Found and broke the garden"
	quest.0A32640B71555B7A.quest_desc: ["The §6Mechanical Crafter§r assembles patterned recipes using rotation. Build it with §6Brass Ingot§r and §6Andesite Alloy§r.", "", "It's the workbench that gives motion physical form — the first step toward forging the core."]
	quest.0A32640B71555B7A.title: "Mechanical Crafter"
	quest.0A332B0F29151AD7.quest_desc: ["Speed lens: mana_lens + sugar + redstone. A spreader with a speed lens fires faster (useful for time-sensitive recipes).", "botania:lens_speed", "0A332B0F29151AD7", "58EC5745B45CE775", "xp"]
	quest.0A332B0F29151AD7.quest_subtitle: "Speed lens"
	quest.0A332B0F29151AD7.title: "Speed Lens"
	quest.0A6AA4F3F564300F.quest_desc: ["Wild starbuncles appear in archwood biomes. Kill or feed them gold_nugget to get shards. 5 shards = 1 charm.", "ars_nouveau:starbuncle_shards", "0A6AA4F3F564300F", "16053A8F6EE166D7", "xp"]
	quest.0A6AA4F3F564300F.quest_subtitle: "Drop from wild starbuncle"
	quest.0A6AA4F3F564300F.title: "Starbuncle Shards"
	quest.0A6BF39DB726103D.quest_subtitle: "Clean energy"
	quest.0A6BF39DB726103D.title: "Crystal Resonance Generator"
	quest.0A893276B7953291.quest_desc: ["The alfheim portal (livingwood + gaia + glimmering livingwood) opens a temporary gateway to Alfheim. Resources: dragonstone, elementium, alfsteel.", "botania:alfheim_portal", "0A893276B7953291", "196C411B80CDC1B4", "xp"]
	quest.0A893276B7953291.quest_subtitle: "Dimension of the elves"
	quest.0A893276B7953291.title: "Alfheim Portal"
	quest.0A8B9B166AC803B2.quest_desc: ["Dark Tower — an obsidian tower at the center. The Ur-Ghast is a giant ghast.", "", "§eReward:§r 70 XP levels + boss trophy"]
	quest.0A8B9B166AC803B2.quest_subtitle: "Supreme ghast of the Dark Tower"
	quest.0A8B9B166AC803B2.title: "Slay the Ur-Ghast"
	quest.0A9B6B7C9450AEED.quest_desc: ["Make §e4§r soups from Pam's.", "pamhc2foodextended:cactussoupitem", "0A9B6B7C9450AEED", "29D2A323979B33C2", "xp_levels"]
	quest.0A9B6B7C9450AEED.quest_subtitle: "19 recipes in Pam's"
	quest.0A9B6B7C9450AEED.title: "Cauldron — Soups"
	quest.0BA7C3D4F7A36A65.quest_desc: ["Use the §bMeteorite Compass§r to find a §7Sky Stone§r meteorite.", "Inside it are the processor §ePresses§r."]
	quest.0BA7C3D4F7A36A65.quest_subtitle: "Meteorite hunt"
	quest.0BA7C3D4F7A36A65.title: "Sky Stone — Meteorite"
	quest.0BC9B86289D37FFF.quest_desc: ["Kill an §capothecarist§r. These mages spawn in §6Mage Towers§r and drop gear pieces + school scrolls.", "", "§eReward:§r XP + a chance to drop an armor set or scroll."]
	quest.0BC9B86289D37FFF.quest_subtitle: "Boss pyromancer"
	quest.0BC9B86289D37FFF.title: "Hunt Apothecarist"
	quest.0C8A6271B4E039EE.quest_desc: ["A chest with §emore capacity§r than the wooden one, and it accepts upgrades.", "§7•§r It can still climb tiers with the tier upgrades.", "The beginning of a real chest system."]
	quest.0C8A6271B4E039EE.title: "Copper Chest"
	quest.0CBB79825E7A5703.quest_desc: ["A mature magebloom plant drops 1-3 mage_bloom. Craft 1 fiber from 4 blooms.", "ars_nouveau:magebloom", "0CBB79825E7A5703", "2B0CE23E5A4A80B7", "xp"]
	quest.0CBB79825E7A5703.quest_subtitle: "Magical fiber"
	quest.0CBB79825E7A5703.title: "Magebloom Fiber"
	quest.0D0D989BDF3BCD68.quest_desc: ["Head out across the §eplains§r and open fields in search of Pam's §6wild gardens§r.", "", "They sprout from the ground like small tufts of plants.", "Break them §7•§r to harvest seeds and assorted ingredients."]
	quest.0D0D989BDF3BCD68.title: "Found and broke the garden"
	quest.0D1B8F4EF84BE177.quest_subtitle: "Getting into the rhythm"
	quest.0D1B8F4EF84BE177.title: "20 Chests Opened"
	quest.0D853F67C689D420.quest_subtitle: "A charming decade"
	quest.0D853F67C689D420.title: "10 Chests Opened"
	quest.0DB980B05B2E81DA.quest_desc: ["The press forces metal sheets — copper, gold, iron. It's what unlocks the fluids tier and the Engineer's finer mechanisms.", "create:mechanical_press", "0DB980B05B2E81DA", "375D5305D8EE896C", "xp"]
	quest.0DB980B05B2E81DA.quest_subtitle: "Pressing & forging"
	quest.0DB980B05B2E81DA.title: "Mechanical Press"
	quest.0DE50D0F47B0B93C.quest_desc: ["&7&o[Final Record Recovered: The Great Collapse]&r", "", "{image:kubejs:textures/static/caos.png width:200 height:100 align:center}", "", "Alas, not even what &3lives is eternal&r, and not even the pursuit of the &5infinite endures forever&r.", "", "When the &3rituals&r reached their &4apex&r, reality could not withstand the pressure. The attempt to materialize the &5Philosopher's Stone&r did not bring &6divinity&r, but &cdevastation&r. The chain reaction tore the fabric of the world.", "", "{@pagebreak}", "", "{image:kubejs:textures/static/deusa.png width:200 height:100 align:center}", "", "From the center of the blast, no object arose, but a presence. An &dancient Goddess&r, worshipped by a people forgotten even before history was written. She came not to save, but to judge.", "", "&o\"O ye, who once feasted upon abundance and, insatiable, dared to covet the ineffable infinite. Ye, whose souls were spared from torment and knew not suffering; ye, holders of plenitude, yet who, in your hubris, yearned to usurp omnipotence... Let this horizon in flames be your final twilight.\"&r", "", "She fragmented reality, scattering the laws of magic and technology to the winds, condemning the survivors to a horizon in flames. &7&oEach mod, once unified, became an isolated island of knowledge — and the Stone, the only bridge to reunite them.&r", "", "{@pagebreak}", "", "&l&nGlossary:&r", "", "&eHubris:&r Excessive pride or self-confidence that defies the gods, leading to one's downfall.", "&eIneffable:&r Something so grand or terrible that it cannot be expressed in words.", "&eTwilight:&r The setting of the sun; figuratively, the end of an era or its decline."]
	quest.0DE50D0F47B0B93C.quest_subtitle: "The End of the Golden Age"
	quest.0DE50D0F47B0B93C.title: "The Great Collapse"
	quest.0E443E43FD0DACCD.quest_desc: ["Here the recipe takes another path: 1 §dlivingwood twig§r + 1 source_gem + 1 gold_ingot in the pattern \" S \" / \" WS\" / \"G  \".", "", "The dominion wand configures familiars (target inventory, filter blocks, etc). Right-click a familiar → right-click the destination.", "ars_nouveau:dominion_wand", "0E443E43FD0DACCD", "1FA90AD515D6EE89", "xp"]
	quest.0E443E43FD0DACCD.quest_subtitle: "Cross-mod — controls familiars"
	quest.0E443E43FD0DACCD.title: "Dominion Wand"
	quest.0E767CA74B3B8EB6.quest_desc: ["§cCursed Spiritual Core§r is the raw result of the sequenced assembly — the three cores fused with the soul, but still unstable.", "", "The combined power of four mods rumbles out of control. The final refinement is still missing."]
	quest.0E767CA74B3B8EB6.title: "Cursed Spiritual Core"
	quest.0FA2DAF0E23BE5FC.quest_desc: ["Manaweave cloth: 4 manasteel_thread (from manasteel_ingot via livingwood twig+thread) + reagent. Used in manaweave armor + decoration.", "botania:manaweave_cloth", "0FA2DAF0E23BE5FC", "475FAC8687D0BA74", "xp"]
	quest.0FA2DAF0E23BE5FC.quest_subtitle: "Manasteel fabric"
	quest.0FA2DAF0E23BE5FC.title: "Manaweave Cloth"
	quest.0FB2719CC60623F1.quest_desc: ["The potion jar stores a single potion and applies it as an area effect (regen, strength). Useful for a permanent base bonus.", "ars_nouveau:potion_jar", "0FB2719CC60623F1", "6770D49D42800C79", "xp"]
	quest.0FB2719CC60623F1.quest_subtitle: "Stores potions"
	quest.0FB2719CC60623F1.title: "Potion Jar"
	quest.0FC8871F46B24FEC.quest_desc: ["To forge it: throw 1 §dmana diamond§r into §6spirit fire§r (an Occultism ritual with chalk_white + cobblestone) → 1 source_gem.", "", "Source_gem is the base of EVERYTHING in Ars. This path requires Botania (a working mana_pool) + Occultism (chalk).", "ars_nouveau:source_gem", "0FC8871F46B24FEC", "4197ADC4485F3046", "xp"]
	quest.0FC8871F46B24FEC.quest_subtitle: "Cross-mod — main path"
	quest.0FC8871F46B24FEC.title: "Source Gem (Mana Diamond)"
	quest.0FE6AB0FC85230BC.quest_desc: ["The iesnium pickaxe is the Occultist's advanced tool. It mines iesnium ore (invisible to ordinary pickaxes) and opens the path to the marid tier.", "", "Marid are the most powerful spirits — whoever reaches here has mastered the whole of occultism."]
	quest.0FE6AB0FC85230BC.quest_subtitle: "Advanced Occultism"
	quest.0FE6AB0FC85230BC.title: "Iesnium Pickaxe"
	quest.10417BD89EB9BC4D.quest_desc: ["Stabilizer tier 1: 4 stone + 1 spirit_attuned_gem. Adds slots to the controller (each stabilizer = +500 slots).", "occultism:storage_stabilizer_tier1", "10417BD89EB9BC4D", "4872AB2199B06D80", "xp"]
	quest.10417BD89EB9BC4D.quest_subtitle: "Expands storage"
	quest.10417BD89EB9BC4D.title: "Storage Stabilizer Tier 1"
	quest.107673CE01A58B3E.quest_desc: ["Goggles: djinni ritual with 4 spirit_attuned_crystal + 1 leather. See all otherworld blocks (iesnium, otherworld_log) without needing a pickaxe.", "occultism:otherworld_goggles", "107673CE01A58B3E", "7F1FC127E2BBDD08", "xp"]
	quest.107673CE01A58B3E.quest_subtitle: "Sees the invisible"
	quest.107673CE01A58B3E.title: "Otherworld Goggles"
	quest.10A59234C40DB59C.quest_desc: ["Purified ink: 1 ink_sac tossed into spirit_fire (ritual). Used in \"pure\" chalk white and book_of_binding_empty.", "occultism:purified_ink", "10A59234C40DB59C", "48A2BB2202B1CF00", "xp"]
	quest.10A59234C40DB59C.quest_subtitle: "Pure ink"
	quest.10A59234C40DB59C.title: "Purified Ink"
	quest.10ECCC51CDCDAB60.quest_desc: ["The §6Attuned Shard§r links Warp Plates to one another, forming a teleport network with scoped destinations.", "waystones:attuned_shard", "10ECCC51CDCDAB60", "17FF1C33B68AF7F8", "xp_levels"]
	quest.10ECCC51CDCDAB60.quest_subtitle: "Link your Warp Plates into a network"
	quest.10ECCC51CDCDAB60.title: "Attuned Shard"
	quest.1119A0C2942258B8.quest_desc: ["As part of the penance, the Goddess &etook the edge&r from tools forged by mortal hands.", "Wood, stone, iron, gold, diamond and netherite &7lost their strength and durability&r. They still work — but barely."]
	quest.1119A0C2942258B8.title: "The Mortal Tools"
	quest.1144C819F885DE00.quest_desc: ["Storage remote: 1 controller + 1 wormhole_frame. Access your storage from anywhere (portable item).", "occultism:storage_remote", "1144C819F885DE00", "0B804178C93C6AFA", "xp"]
	quest.1144C819F885DE00.quest_subtitle: "Remote access"
	quest.1144C819F885DE00.title: "Storage Remote"
	quest.1166CF581183294D.quest_desc: ["The §ePot§r is the utensil for §6soups and stews§r.", "", "Combine fresh water, vegetables and meats for hot dishes that fill the hunger bar nicely.", "Reusable: once made, cook to your heart's content."]
	quest.1166CF581183294D.quest_subtitle: "Soups and stews"
	quest.1166CF581183294D.title: "Pot"
	quest.11F1769AC021A9A6.quest_desc: ["A hose pulley draws fluids from a body of liquid (ocean, lake, lava). An infinite source if the body is > 10000 blocks.", "create:hose_pulley", "11F1769AC021A9A6", "2CF91535A58A43AF", "xp"]
	quest.11F1769AC021A9A6.quest_subtitle: "Infinite fluid suction"
	quest.11F1769AC021A9A6.title: "Hose Pulley"
	quest.12285E91B2823CD6.quest_desc: ["Arranged in a grid, these crafters assemble any complex recipe on their own. It's like having a thousand hands forging in parallel.", "", "You'll need them to forge the §dPrecision Mechanism§r — a critical mid-game part of Create."]
	quest.12285E91B2823CD6.quest_subtitle: "Automated crafting"
	quest.12285E91B2823CD6.title: "Mechanical Crafter"
	quest.12CE6E9875DD1591.quest_desc: ["The schematicannon fires blocks to build a saved schematic. Combine it with a schematic and quill (next quest) and a brick of fuel.", "create:schematicannon", "12CE6E9875DD1591", "48EFA13F3F593537", "xp"]
	quest.12CE6E9875DD1591.quest_subtitle: "Build structures automatically"
	quest.12CE6E9875DD1591.title: "Schematicannon"
	quest.131FD257771A6236.quest_desc: ["§5The Keeper§r — a wraith found in ruins. An §dender§r-element boss.", "", "Drop: rare §6spell scrolls§r + §6keeper soul§r."]
	quest.131FD257771A6236.quest_subtitle: "Arcane wraith"
	quest.131FD257771A6236.title: "Boss: The Keeper"
	quest.1384646025CA3D53.quest_desc: ["The mycelial link generates mana from mushroom farms. Useful in swamp/mushroom_island.", "ars_nouveau:mycelial_sourcelink", "1384646025CA3D53", "07C90040FFF61F94", "xp"]
	quest.1384646025CA3D53.quest_subtitle: "Link via mushrooms"
	quest.1384646025CA3D53.title: "Source Link Mycelial"
	quest.139CAC5805D05307.quest_desc: ["Source gem block: 9 source_gem → 1 block. Storage + decoration + a component of several structures.", "ars_nouveau:source_gem_block", "139CAC5805D05307", "2D80846FDD0AA731", "xp"]
	quest.139CAC5805D05307.quest_subtitle: "Compacted block"
	quest.139CAC5805D05307.title: "Source Gem Block"
	quest.139D02C0B765CB8B.quest_desc: ["Chalk white pure: 4 purified_ink + 1 stick. More precise pentacles = higher chance of ritual success.", "occultism:chalk_white", "139D02C0B765CB8B", "41A82B4ED5C7135C", "xp"]
	quest.139D02C0B765CB8B.quest_subtitle: "Quality chalk"
	quest.139D02C0B765CB8B.title: "Chalk White (Pure)"
	quest.13AA5F368949DF26.quest_desc: ["The Twilight Forest's opening boss. Find it in mossy stone ruins.", "", "§eReward:§r 20 XP levels + boss trophy"]
	quest.13AA5F368949DF26.quest_subtitle: "The serpent of the ruins"
	quest.13AA5F368949DF26.title: "Slay the Naga"
	quest.13F667C677069107.quest_desc: ["Place a pure_daisy next to logs (not planks!) — it gradually converts them into livingwood. Base material for mana_spreader, mana_pylon and many other structures.", "botania:livingwood", "13F667C677069107", "3CFE71FB96516873", "xp"]
	quest.13F667C677069107.quest_subtitle: "Living wood"
	quest.13F667C677069107.title: "Livingwood"
	quest.1421D434596C84D1.quest_desc: ["Dimensional matrix: djinni ritual with 1 storage_base + 1 nether_star + rare items. The heart of the storage system.", "occultism:dimensional_matrix", "1421D434596C84D1", "455D9ED8E10E34A9", "xp"]
	quest.1421D434596C84D1.quest_subtitle: "Inter-dimensional matrix"
	quest.1421D434596C84D1.title: "Dimensional Matrix"
	quest.142572AABD3DFC3A.quest_desc: ["To forge it: 1 §6spirit attuned crystal§r in the imbuement_chamber → 4 source_gem + 1000 source mana.", "", "A path 4× as efficient for mass production. The crystal comes from amethyst_block (a turning point — Magical Agglutinate).", "ars_nouveau:source_gem", "142572AABD3DFC3A", "6057B872DF053AA6", "xp"]
	quest.142572AABD3DFC3A.quest_subtitle: "Cross-mod — premium path"
	quest.142572AABD3DFC3A.title: "Source Gem (Spirit Crystal)"
	quest.143A3595A3A9E8E8.quest_desc: ["The mana distributor receives mana from ONE spreader and redistributes it to up to 4 adjacent spreaders. Handy for feeding multiple farms.", "botania:mana_distributor", "143A3595A3A9E8E8", "78081CFC12598258", "xp"]
	quest.143A3595A3A9E8E8.quest_subtitle: "Distributes mana to multiple pools"
	quest.143A3595A3A9E8E8.title: "Mana Distributor"
	quest.149688E1047E1961.quest_desc: ["Ritual warding protects an area from creature spawns. Useful for bases.", "ars_nouveau:ritual_warping", "149688E1047E1961", "2B1B4C0772E2CB93", "xp"]
	quest.149688E1047E1961.quest_subtitle: "Area protection"
	quest.149688E1047E1961.title: "Ritual Warding"
	quest.14CD28F6A9C0C904.quest_desc: ["The first real backpack, with much more space than the leather one.", "§7•§r It already accepts §eUpgrades§r, so it's the foundation for everything else.", "Hold it and click to open it anywhere."]
	quest.14CD28F6A9C0C904.quest_subtitle: "More space"
	quest.14CD28F6A9C0C904.title: "Copper Backpack"
	quest.14CE03D862C378EC.quest_desc: ["Automatically merges items into blocks: nuggets become ingots, ingots become blocks.", "§7•§r Saves space by storing everything already compacted.", "Great for mass resource mining."]
	quest.14CE03D862C378EC.quest_subtitle: "Turns things into blocks automatically"
	quest.14CE03D862C378EC.title: "Upgrade: Compacting"
	quest.151AC074067A49BD.quest_desc: ["The ritual binding tablet lets you convert shards into charms. Run it at the brazier with shards + base items.", "ars_nouveau:ritual_binding", "151AC074067A49BD", "4D7C38BC87675D00", "xp"]
	quest.151AC074067A49BD.quest_subtitle: "Binds familiar shards → charm"
	quest.151AC074067A49BD.title: "Ritual Binding"
	quest.15597489E4770386.quest_desc: ["A gearshift reverses the shaft's direction when it receives redstone. Useful for reversible deployers and pumps.", "create:gearshift", "15597489E4770386", "00C29A27B9D2B7C4", "xp"]
	quest.15597489E4770386.quest_subtitle: "Reverses direction via redstone"
	quest.15597489E4770386.title: "Gearshift"
	quest.156570B45AB0518D.quest_desc: ["Like §ePickup§r, but pulls items and XP toward you from §bafar§r.", "§7•§r The radius is much larger — it clears the floor of an entire area.", "Be careful not to pull in what you don't want; use the filters."]
	quest.156570B45AB0518D.quest_subtitle: "Attracts items from afar"
	quest.156570B45AB0518D.title: "Upgrade: Magnet"
	quest.159F86B53CE63848.quest_desc: ["§2Wilden Chimera§r — Ars Nouveau boss. Summon it with a §6Wilden Chimera Spawn Egg§r or summon it at the §6Ritual Brazier of Wilden Summoning§r.", "", "3 phases (defender/hunter/stalker), each with its own mechanics.", "", "§eReward:§r 50 XP levels + Wilden Trophy"]
	quest.159F86B53CE63848.quest_subtitle: "The wild beast of the forest"
	quest.159F86B53CE63848.title: "Slay Wilden Chimera"
	quest.15C4F7F1763E716E.quest_desc: ["The vitalic link generates mana from nearby creature spawns. Good for creature farms.", "ars_nouveau:vitalic_sourcelink", "15C4F7F1763E716E", "79E6B0FA395A1851", "xp"]
	quest.15C4F7F1763E716E.quest_subtitle: "Mana link via life"
	quest.15C4F7F1763E716E.title: "Source Link Vitalic"
	quest.15E2785AE7B5C110.quest_desc: ["There are 70+ glyphs available in Ars. Build a collection of at least 25 — the apprentice threshold. Each glyph is unlocked at the scribes_table.", "ars_nouveau:blank_glyph", "15E2785AE7B5C110", "5910EBEDB3B62D02", "xp"]
	quest.15E2785AE7B5C110.quest_subtitle: "Learn 25+ glyphs"
	quest.15E2785AE7B5C110.title: "Glyph Collection"
	quest.16011FCD6C61AA02.quest_desc: ["The source gem is the Arcanist's mana currency. Without it, nothing is imbued, nothing is channeled, nothing is enchanted.", "", "There are two ways to obtain it:", "§71)§r throw a §dmana diamond§r into the occultists' spirit fire — one gem comes out", "§72)§r place a §dspirit attuned crystal§r in the imbuement chamber — four gems come out (but it requires the full Druid path + Agglutinate)"]
	quest.16011FCD6C61AA02.quest_subtitle: "The base of all Ars"
	quest.16011FCD6C61AA02.title: "Source Gem"
	quest.16035ED5ED581BED.quest_desc: ["Afrit essence: afrit ritual (with nether_star) → essence. Used in demonic_machine recipes.", "occultism:afrit_essence", "16035ED5ED581BED", "78B089A886311EBF", "xp"]
	quest.16035ED5ED581BED.quest_subtitle: "Demonic essence"
	quest.16035ED5ED581BED.title: "Afrit Essence"
	quest.163565E425D947A6.quest_desc: ["There are ~10 Ars forms: projectile, touch, self, area, beam, underfoot, etc. Each defines HOW the spell manifests. Place at LEAST 5 different forms at the scribes_table.", "ars_nouveau:glyph_orbit", "163565E425D947A6", "609BA2BEF3159563", "xp"]
	quest.163565E425D947A6.quest_subtitle: "Basic and advanced forms"
	quest.163565E425D947A6.title: "Form Collection (Glyphs)"
	quest.168FAA46D89F457B.quest_desc: ["§eDough§r + §eBakeware§r.", "pamhc2foodextended:pancakesitem", "168FAA46D89F457B", "5865474D0D5699A2", "xp_levels"]
	quest.168FAA46D89F457B.quest_subtitle: "First dish"
	quest.168FAA46D89F457B.title: "Pancakes"
	quest.16D79B3A3A9C95FB.quest_desc: ["Dark Tower in the Twilight. Endgame boss of the Twilight Forest.", "", "§eReward:§r 70 XP levels + boss trophy"]
	quest.16D79B3A3A9C95FB.quest_subtitle: "Lord of the Dark Tower"
	quest.16D79B3A3A9C95FB.title: "Tier 6: Ur-Ghast"
	quest.16EDE5F05169464C.quest_desc: ["Spirit fire: build the white impure pentacle + flint_and_steel in the center → spirit_fire ignites. Toss items in to convert them (cobblestone→otherstone, amethyst_block→spirit_attuned_crystal, etc).", "occultism:spirit_fire", "16EDE5F05169464C", "3C1C96277D2B9B1D", "xp"]
	quest.16EDE5F05169464C.quest_subtitle: "Spirit fire ritual"
	quest.16EDE5F05169464C.title: "Spirit Fire"
	quest.1706DED5F3EDA6B9.quest_desc: ["Explore the §eshaded corners and mushroom fields§r.", "", "In damp, dark lands grow the most uncommon §6wild gardens§r.", "Break them §7•§r and take home ingredients that few know about."]
	quest.1706DED5F3EDA6B9.title: "Found and broke the garden"
	quest.17483F40DBEC0AFB.quest_desc: ["§eThis chapter guides EQSMP's boss progression.§r", "", "The main line covers 8 milestones — essential bosses that open the path to the endgame.", "Side quests add variety: elemental bosses, hard modes, and each mod's unique masters.", "", "§7Start with the Naga (easiest) and work up to the Harbinger (hardest)."]
	quest.17483F40DBEC0AFB.quest_subtitle: "Confront the world's bosses"
	quest.17483F40DBEC0AFB.title: "The Path of the Hunter"
	quest.17D98576B8A56FF4.quest_desc: ["Salvation lies in &btranscending the ordinary&r. Tools and weapons beyond the mortal — &6Silent Gear&r, magic, engineering — don't carry the curse and hit &aharder&r.", "Walk the &eMod Paths&r and forge your own."]
	quest.17D98576B8A56FF4.title: "Forge Your Own Path"
	quest.18D3E4535B857760.quest_desc: ["Dragon familiar: afrit ritual + ender_dragon scales. Combat support + auto-flight.", "occultism:familiar_ring", "18D3E4535B857760", "4CB7FA9301707C7D", "xp"]
	quest.18D3E4535B857760.quest_subtitle: "Advanced familiar"
	quest.18D3E4535B857760.title: "Dragon Familiar"
	quest.1922B0380E2A5219.quest_desc: ["The §eGrave Plate§r identifies and decorates the grave, marking whose resting place it is.", "", "§7•§r Useful for telling graves apart on a server with several players.", "§7•§r Also works as a memorial ornament in a homemade cemetery."]
	quest.1922B0380E2A5219.quest_subtitle: "Identifies the grave"
	quest.1922B0380E2A5219.title: "Grave Plate"
	quest.192D827126D8DF67.quest_desc: ["There's candle_white, candle_red, etc. Each chalk color requires the corresponding candle in the pentacle.", "occultism:candle_white", "192D827126D8DF67", "58ADEF202927D24C", "xp"]
	quest.192D827126D8DF67.quest_subtitle: "Ritual candles"
	quest.192D827126D8DF67.title: "Collection of Candles"
	quest.1946293FE32510F3.quest_desc: ["Marid master miner: marid ritual + iesnium_pickaxe + crystal_apparatus. Mines random ore in the background — Occultism's advanced farm.", "occultism:miner_marid_master", "1946293FE32510F3", "3EF3B0386264A169", "xp"]
	quest.1946293FE32510F3.quest_subtitle: "Infinite mining"
	quest.1946293FE32510F3.title: "Marid Miner (advanced)"
	quest.19D72A7F5EE326F5.quest_desc: ["The kekimurus eats cake (vanilla) to generate mana — ~120k mana per cake. Auto-feed via a Create cake-stacking belt.", "botania:kekimurus", "19D72A7F5EE326F5", "257750CBA4DFB6F3", "xp"]
	quest.19D72A7F5EE326F5.quest_subtitle: "Cake-powered generator"
	quest.19D72A7F5EE326F5.title: "Kekimurus"
	quest.19D8E5E2A48177D3.quest_desc: ["Infused lenses (eye slot via curio) reveal otherworld blocks without needing a specific pickaxe.", "occultism:infused_lenses", "19D8E5E2A48177D3", "5A51DCC506940669", "xp"]
	quest.19D8E5E2A48177D3.quest_subtitle: "Occultist's sight"
	quest.19D8E5E2A48177D3.title: "Infused Lenses"
	quest.1AFB6301F67149E2.quest_desc: ["Greater mana ring: 2× ring + 1× gaia_ingot or similar. 5x the capacity. Advanced portable storage.", "botania:mana_ring_greater", "1AFB6301F67149E2", "38165B1481985937", "xp"]
	quest.1AFB6301F67149E2.quest_subtitle: "Upgraded ring"
	quest.1AFB6301F67149E2.title: "Greater Mana Ring"
	quest.1B83CECB49BDB010.quest_desc: ["There are ~15 augments: amplify, dampen, extend_time, accelerate, fortune, sensitive, etc. They modify intensity/duration/behavior.", "ars_nouveau:glyph_extend_time", "1B83CECB49BDB010", "22236E9D8F8AF6B1", "xp"]
	quest.1B83CECB49BDB010.quest_subtitle: "Modifier augments"
	quest.1B83CECB49BDB010.title: "Augment Collection"
	quest.1C069DDAD9AE8EA6.quest_desc: ["Terrasteel chestplate: 8× terrasteel_ingot. Boosts defense + mana regen.", "botania:terrasteel_chestplate", "1C069DDAD9AE8EA6", "20F4927EB6447495", "xp"]
	quest.1C069DDAD9AE8EA6.quest_subtitle: "Advanced chestplate"
	quest.1C069DDAD9AE8EA6.title: "Terrasteel Chestplate"
	quest.1CE40655E324434F.quest_desc: ["The §eDecorative Grave§r is a purely §bdecorative§r memorial.", "", "§7•§r Use it to build cemeteries, shrines or tributes at your base.", "§7•§r It doesn't store items or appear when you die: it's just aesthetics."]
	quest.1CE40655E324434F.quest_subtitle: "Memorial"
	quest.1CE40655E324434F.title: "Decorative Grave"
	quest.1D2BC1E862147C51.quest_desc: ["Cataclysm. Bastion in the Nether. Alternative tier 6 boss.", "", "§eReward:§r 75 XP levels + drop"]
	quest.1D2BC1E862147C51.quest_subtitle: "Monstrosity of the Nether"
	quest.1D2BC1E862147C51.title: "Side: Netherite Monstrosity"
	quest.1D5762182FF288D9.quest_desc: ["When all hope was fading, the &dGoddess&r intervened. She &aspared humanity&r from final destruction.", "But mercy &eis not&r the same as forgiveness."]
	quest.1D5762182FF288D9.title: "The Goddess's Gift"
	quest.1D7156B161DD41D4.quest_desc: ["Amethyst golem charm: 5 amethyst_shard + ritual binding. Automatically collects amethyst from geodes.", "ars_nouveau:amethyst_golem_charm", "1D7156B161DD41D4", "6FBAD61155993851", "xp"]
	quest.1D7156B161DD41D4.quest_subtitle: "Amethyst-collecting familiar"
	quest.1D7156B161DD41D4.title: "Amethyst Golem"
	quest.1D7E669BF9E90286.quest_desc: ["The strongest material Botania can offer. Forged on the Terra Plate, consuming half a million mana.", "", "It's the base of the §dSpiritual Core§r — the fourth and last of the magical pillars.", "botania:terrasteel_ingot", "1D7E669BF9E90286", "6DD71CCABA82B479", "xp"]
	quest.1D7E669BF9E90286.quest_subtitle: "Advanced material"
	quest.1D7E669BF9E90286.title: "Terrasteel Ingot"
	quest.1D8A94E00FA820E7.quest_subtitle: "Pushing out"
	quest.1D8A94E00FA820E7.title: "Export Bus"
	quest.1D8C001F1FD16C14.quest_desc: ["Stores all three forms together: §enugget§r, §eingot§r and §eblock§r.", "§7•§r Put in an ingot and it converts between the forms on its own.", "No more back-and-forth crafting blocks just to store them."]
	quest.1D8C001F1FD16C14.quest_subtitle: "Block/ingot/nugget together"
	quest.1D8C001F1FD16C14.title: "Compacting Drawer"
	quest.1D9DB440D41F4D36.quest_desc: ["§dBook of Binding (Djinni)§r was unlocked by the §ePure Mana Crystal§r — now you can bind a greater spirit from Occultism.", "", "The djinni opens rituals of power far beyond the humble foliot."]
	quest.1D9DB440D41F4D36.title: "Pact with the Djinni"
	quest.1DAECECBF4CA4357.quest_subtitle: "The chip factory"
	quest.1DAECECBF4CA4357.title: "Inscriber"
	quest.1DFACF67B8011238.quest_desc: ["The §eMixing Bowl§r is used to combine raw ingredients.", "", "Salads, fillings and light doughs pass through it.", "Like the other utensils, it §6stays in your inventory§r after the recipe."]
	quest.1DFACF67B8011238.title: "Mixing Bowl"
	quest.1E13439C75C88343.quest_desc: ["Craft or obtain the §6Gold Tome§r. Each tier allows §emore inscribed spells§r and §emore powerful casts§r.", "", "§7Crafting: recipe similar to the base spell book, with the ingredient of the corresponding tier."]
	quest.1E13439C75C88343.quest_subtitle: "Intermediate tier"
	quest.1E13439C75C88343.title: "Gold Tome"
	quest.1E74F7CCF3383CE7.quest_desc: ["The djinni pact book unlocks the Occultist's middle tier. Djinn serve in advanced rituals.", "", "The recipe here demands a §dPure Mana Crystal§r — because djinn only accept pacts forged in absolute purity.", "occultism:book_of_binding_djinni", "1E74F7CCF3383CE7", "0CB020B97E4A3551", "xp"]
	quest.1E74F7CCF3383CE7.quest_subtitle: "F3 Requirement — Mana Crystal"
	quest.1E74F7CCF3383CE7.title: "Book of Binding (Djinni)"
	quest.1EB207A4DB3F75BC.quest_desc: ["A depot holds an item still for processing (drill, saw, deployer, press). A belt alternative for sequential processes.", "create:depot", "1EB207A4DB3F75BC", "49286BE8FFDF995F", "xp"]
	quest.1EB207A4DB3F75BC.quest_subtitle: "Static platform for processing"
	quest.1EB207A4DB3F75BC.title: "Depot"
	quest.1FFA1B0C43DE05B3.quest_desc: ["The agricarnation speeds up the growth of nearby crops. Mana cost per crop. Combine with vegetal_baby for massive farms.", "botania:agricarnation", "1FFA1B0C43DE05B3", "03EB692AA9E4B9C4", "xp"]
	quest.1FFA1B0C43DE05B3.quest_subtitle: "Growth flower"
	quest.1FFA1B0C43DE05B3.title: "Agricarnation"
	quest.200A178BD7771EB8.quest_desc: ["§eKinetic Core§r — this phase's milestone. The foliot ritual purifies the §ccorrupted core§r, locking Create's motion into a stable form.", "", "It's the cross-key: it unlocks the next level of §aBotania§r and §bArs Nouveau§r."]
	quest.200A178BD7771EB8.title: "The Kinetic Core"
	quest.204066C0F1D2B212.quest_desc: ["The §eCutting Board§r is your first kitchen tool.", "", "Use it in recipes that call for slicing §7•§r meats, fruits and vegetables.", "It stays in the crafting grid alongside the ingredients and §6is not consumed§r. A good start for the kitchen."]
	quest.204066C0F1D2B212.quest_subtitle: "First tool"
	quest.204066C0F1D2B212.title: "Cutting Board"
	quest.20557B0806A699B9.quest_desc: ["Here the recipe takes another route: 4× §6otherstone slab§r → 1 diluted_pool. Smaller capacity (10000 mana) but cheap, ideal for the runic_altar.", "botania:diluted_pool", "20557B0806A699B9", "7E01AAFB5B83CA6E", "xp"]
	quest.20557B0806A699B9.quest_subtitle: "Cross-mod F1 — smaller pool"
	quest.20557B0806A699B9.title: "Diluted Pool"
	quest.205AE6A03613BFE6.quest_desc: ["A conjuration catalyst under the mana_pool enables special recipes (mana_diamond, extra mana_pearl, etc). Permanent once placed.", "botania:conjuration_catalyst", "205AE6A03613BFE6", "616310B12323C142", "xp"]
	quest.205AE6A03613BFE6.quest_subtitle: "Mana_pool catalyst"
	quest.205AE6A03613BFE6.title: "Conjuration Catalyst"
	quest.209FD25B5B9ADBC1.quest_desc: ["Wixie charm + ritual binding → wixie pet. Program recipes for it to craft automatically at the enchanting_apparatus.", "ars_nouveau:wixie_charm", "209FD25B5B9ADBC1", "152240C1374F0428", "xp"]
	quest.209FD25B5B9ADBC1.quest_subtitle: "Crafter familiar"
	quest.209FD25B5B9ADBC1.title: "Wixie Charm"
	quest.20DA5D1B156DA58F.quest_desc: ["Self applies the spell to the caster. Critical for haste, healing and jump-boost combinations.", "ars_nouveau:glyph_self", "20DA5D1B156DA58F", "3DE1CFCE3E6AB402", "xp"]
	quest.20DA5D1B156DA58F.quest_subtitle: "Form — on yourself"
	quest.20DA5D1B156DA58F.title: "Glyph: Self"
	quest.21B3E46BB4545D75.quest_desc: ["The §eTome of Disenchantment§r §cremoves§r the enchantments from an item so you can §brecover them§r.", "", "§7•§r The extracted enchantments can be reapplied to other gear.", "§7•§r Great for reusing a rare enchantment before discarding the piece."]
	quest.21B3E46BB4545D75.quest_subtitle: "Recovers enchantments"
	quest.21B3E46BB4545D75.title: "Tome of Disenchantment"
	quest.223B47023739FF32.quest_subtitle: "More speed"
	quest.223B47023739FF32.title: "Crafting Co-Processor"
	quest.224608376584E2BA.quest_desc: ["Create's §6Mechanical Arm§r was unlocked by the §ePure Mana Crystal§r.", "", "It moves and distributes items between depots and machines — the automatic arm essential for the sequenced assembly of the final phase."]
	quest.224608376584E2BA.title: "Mechanical Arm Unlocked"
	quest.22B64EE5468FBBBF.quest_desc: ["Amplify intensifies the preceding effect. Heal + 3× amplify = massive healing. Damage spells benefit too.", "ars_nouveau:glyph_amplify", "22B64EE5468FBBBF", "1DA1807EAEC8D328", "xp"]
	quest.22B64EE5468FBBBF.quest_subtitle: "Augment — increases power"
