	quest.444F6806A0BEDC66.title: "Source Jar"
	quest.447384705C535937.quest_desc: ["The schematic and quill selects an area (2 shift+right-clicks) and saves it as a schematic for reuse. Combine with the schematicannon for mass building.", "create:schematic_and_quill", "447384705C535937", "434BDD45C2930C5A", "xp"]
	quest.447384705C535937.quest_subtitle: "Save structures"
	quest.447384705C535937.title: "Schematic and Quill"
	quest.44B224C543FC87C1.quest_desc: ["The rune altar is where mana takes elemental form. Here runes of water, fire, earth and air are forged.", "", "To build it, you'll need a §dKinetic Core§r — without mastery of movement, the runes won't set."]
	quest.44B224C543FC87C1.quest_subtitle: "Rune crafting"
	quest.44B224C543FC87C1.title: "Runic Altar"
	quest.44C263A885C4364B.quest_desc: ["Adds a §ecrafting§r grid right inside the backpack itself.", "§7•§r Craft using the stored items, no crafting table needed.", "Combine it with Compacting and you become a walking factory."]
