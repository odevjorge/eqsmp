	quest.47F7C68BC6B3730D.title: "Dust of Vanishing"
	quest.48784E0754EEE1D6.quest_desc: ["The gaia pylon (4× terrasteel_ingot + 1× elementium + 1× black_lotus) is placed at the center of the arena. Beacon_block + lapis_block = minimum arena.", "botania:gaia_pylon", "48784E0754EEE1D6", "3B6C9390F05333D9", "xp"]
