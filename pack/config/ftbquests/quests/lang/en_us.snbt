	quest.2DECEB0DC4506B13.title: "Otherworld Bird"
	quest.2DFD01E33932BE0C.quest_desc: ["There are 4 archwood biomes: cascading (blue), blazing (red), vexing (purple), flourishing (green). Each spawns different creatures (starbuncles, drygmys, whirlisprigs).", "ars_nouveau:purple_archwood_sapling", "2DFD01E33932BE0C", "04FD37EC71D8D336", "xp"]
