	quest.45260D3E9717B28D.quest_desc: ["Get a Lexica Botania (1 book + 1 sapling on the crafting table). This is your in-game guide to ALL functional flowers, mana mechanics and Botania progression.", "botania:lexicon", "45260D3E9717B28D", "5E742F0287814D1E", "xp"]
