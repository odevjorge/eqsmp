	quest.7000000000000090.quest_desc: ["Find and break an §eArid Garden§r (deserts/savannas) to collect its produce and seeds.", "pamhc2crops:aridgarden", "7000000000000090", "7000000000000091", "xp_levels"]
	quest.7000000000000090.title: "Found and broke the garden"
	quest.708649A49749F090.quest_desc: ["Projectile sends the spell in a linear arc. The most common base form. Learn it at the scribes_table with 1 source_gem.", "ars_nouveau:glyph_projectile", "708649A49749F090", "427F82C85D63E58A", "xp"]
	quest.708649A49749F090.quest_subtitle: "Form — projection"
	quest.708649A49749F090.title: "Glyph: Projectile"
	quest.70C75B22504A93AA.quest_desc: ["Mage block: 4 magebloom_fiber + 4 cobblestone. A component of the apprentice_spell_book and several structures.", "ars_nouveau:mage_block", "70C75B22504A93AA", "2A9192390CAE2AB8", "xp"]
	quest.70C75B22504A93AA.quest_subtitle: "Magical base block"
	quest.70C75B22504A93AA.title: "Mage Block"
	quest.70D99441B57D3336.quest_subtitle: "Fuel-powered energy"
	quest.70D99441B57D3336.title: "Vibration Chamber"
	quest.712E3EBE20BC182A.quest_desc: ["There's the foliot crusher (mill), foliot lumberjack (chops), foliot transport (moves items). Each needs a ritual + book_foliot. Place at least 2 different types.", "occultism:miner_foliot_unspecialized", "712E3EBE20BC182A", "5DC60BE404ACB014", "xp"]
	quest.712E3EBE20BC182A.quest_subtitle: "Foliot familiars"
	quest.712E3EBE20BC182A.title: "Collection of Foliot Workers"
	quest.71E123832BF54B46.quest_desc: ["Apply this upgrade to a chest or barrel to raise its §etier§r.", "§7•§r Each tier adds more storage slots.", "There's a tier ladder: copper, iron, gold, diamond and netherite."]
	quest.71E123832BF54B46.quest_subtitle: "Increases capacity"
	quest.71E123832BF54B46.title: "Tier Upgrade"
	quest.7208101A847E11D6.quest_desc: ["Sacrificial bowl: 4 stone + 1 candle. Place them around the pentacle to hold the ritual's item ingredients.", "occultism:sacrificial_bowl", "7208101A847E11D6", "57CB5B3510513471", "xp"]
	quest.7208101A847E11D6.quest_subtitle: "Item receptacle"
	quest.7208101A847E11D6.title: "Sacrificial Bowl"
	quest.721CC1C009E5896D.quest_desc: ["The bellethorn deals damage to nearby mobs. Good passive defense for a base, at a mana cost.", "botania:bellethorn", "721CC1C009E5896D", "7ECE7D12D9614CFD", "xp"]
	quest.721CC1C009E5896D.quest_subtitle: "Flower that attacks mobs"
	quest.721CC1C009E5896D.title: "Bellethorn"
	quest.725715C7A40ED673.quest_desc: ["Here the recipe takes a different path: 1 §damethyst block§r (which requires the Magical Agglutinate!) tossed into spirit_fire → 1 spirit_attuned_crystal.", "", "The crystal is used in ritual candles, the source_gem path (4× via Imbuement Chamber!), advanced demonic settings.", "occultism:spirit_attuned_crystal", "725715C7A40ED673", "73467BA07BBE6703", "xp"]
	quest.725715C7A40ED673.quest_subtitle: "Cross-mod — F1 cascade crystal"
	quest.725715C7A40ED673.title: "Attuned Crystal"
	quest.72625D28CAB980C6.quest_desc: ["Cataclysm. Soul Stained Steel Factory.", "", "§eReward:§r 80 XP levels + drop"]
	quest.72625D28CAB980C6.quest_subtitle: "The Cursed Animatronic"
	quest.72625D28CAB980C6.title: "Side: Maledictus"
	quest.72E4F7AF06392851.quest_desc: ["Build a pentacle from chalk white_impure + 4 sacrificial_bowl + 1 golden_sacrificial_bowl + 1 candle_white. Drop ritual_dummy + ingredients into the golden one → the ritual activates.", "", "Start with summon_foliot_crusher to see the system in action.", "occultism:ritual_dummy/summon_foliot_crusher", "72E4F7AF06392851", "2C445678B05A37C7", "xp"]
	quest.72E4F7AF06392851.quest_subtitle: "Perform a summoning"
	quest.72E4F7AF06392851.title: "First Ritual"
	quest.7322CCE81684BE59.quest_desc: ["You've completed the EQSMP Druid path! You've mastered mana, runes (with the Pure Mana Crystal as a requirement), terrasteel, Gaia and Alfheim.", "", "§7EQSMP recipes you learned:§r", "§7•§r mana_pool/diluted_pool with otherstone (Magical Agglutinate)", "§7•§r runic_altar with nucleo_cinetico (Kinetic Core)", "§7•§r elemental runes with cristal_mana_pura (Pure Mana Crystal)", "§7•§r mana_pylon with source_gem (Ars)", "", "Next paths: Ars Nouveau, Occultism, Philosopher's Stone.", "botania:gaia_pylon", "7322CCE81684BE59", "0E48EA5B34B42A67", "xp", "4CB24D6EC5425209", "xp_levels", "1A2B3C4D5E6F012A", "1A2B3C4D5E6F0001", "random", "gear", "You have mastered the Druid", "078A1B823AF67F55", "checkmark"]
	quest.7322CCE81684BE59.quest_subtitle: "You have mastered the Druid"
	quest.7322CCE81684BE59.title: "Botania Mastery"
	quest.7398D62E72C41A7A.quest_desc: ["Funnels move items between inventories and belts/depots. Direction is configurable via click. The andesite variant is slower; brass is configurable.", "create:andesite_funnel", "7398D62E72C41A7A", "0F0EDC03EE84C0BE", "xp"]
	quest.7398D62E72C41A7A.quest_subtitle: "Inventory input/output"
	quest.7398D62E72C41A7A.title: "Funnel"
	quest.73994EE3D6D83E4F.quest_desc: ["Collect petals of all 16 mystical colors. Bone meal on a mystical_flower speeds up the collection. Needed for varied apothecary recipes.", "botania:black_petal", "73994EE3D6D83E4F", "6C6E0E6DAECB9D07", "xp"]
	quest.73994EE3D6D83E4F.quest_subtitle: "All 16 colors"
	quest.73994EE3D6D83E4F.title: "Petal Collection"
	quest.74929077A84856C4.quest_desc: ["To save is not to &eabsolve&r. The Goddess did not free mortals from &cpaying for their sins&r.", "The world was reborn &chostile&r: creatures grow &cstronger with each passing day&r. The beginning will be brutal."]
	quest.74929077A84856C4.title: "Justice Exacts Its Price"
	quest.74ADB5255F953B57.quest_desc: ["Train track: 1 train_casing + 6 iron_sheet + 2 andesite_alloy. Place it in a loaded chunk or it deactivates.", "create:track", "74ADB5255F953B57", "475D616AB46046A9", "xp"]
	quest.74ADB5255F953B57.quest_subtitle: "Train rail"
	quest.74ADB5255F953B57.title: "Train Track"
	quest.74F05A1762C414E6.quest_desc: ["You've completed the EQSMP Occultist's path! You've mastered rituals, summonings (foliot/djinni/afrit/marid), the storage system and iesnium mining.", "", "§7EQSMP recipes you learned:§r", "§7•§r datura_seeds via apothecary (Botania, no grass loot)", "§7•§r spirit_attuned_gem via amethyst_shard (cheaper)", "§7•§r spirit_attuned_crystal via amethyst_block (Agglutinate cascade)", "§7•§r spirit_lantern with manasteel_ingot (Botania)", "§7•§r book_of_binding_foliot with aglutinado_magico (Magical Agglutinate)", "§7•§r book_of_binding_djinni with cristal_mana_pura (Pure Mana Crystal)", "§7•§r otherstone required for Botania's mana_pool (Magical Agglutinate)", "", "Remaining paths: Philosopher's Stone (the absolute endgame).", "occultism:book_of_binding_marid", "74F05A1762C414E6", "57E7792012632927", "xp", "2B90E16AFC82227A", "xp_levels", "1A2B3C4D5E6F012C", "1A2B3C4D5E6F0001", "random", "gear", "You've mastered the Occultist", "2E83C37E7EB2C13D", "checkmark"]
	quest.74F05A1762C414E6.quest_subtitle: "You've mastered the Occultist"
	quest.74F05A1762C414E6.title: "Occult Mastery"
	quest.755599C495DADCB4.quest_desc: ["Hard version of the Gaia. Summoned with 4 gaia spirits. Reward: dragonstone.", "", "§eReward:§r 80 XP levels + drop"]
	quest.755599C495DADCB4.quest_subtitle: "Hard mode"
	quest.755599C495DADCB4.title: "Side: Gaia Guardian II"
	quest.75560E86A21DAD18.quest_desc: ["§eSmelts§r ores and food while you carry the backpack.", "§7•§r It needs fuel, just like a normal furnace.", "Grab the ore on pickup and it comes out smelted and ready to use."]
	quest.75560E86A21DAD18.quest_subtitle: "Smelts while you carry it"
	quest.75560E86A21DAD18.title: "Upgrade: Auto-Smelting"
	quest.759875C297FF8E87.quest_subtitle: "Network sees the chest"
	quest.759875C297FF8E87.title: "Storage Bus"
	quest.7600802B547E9192.quest_desc: ["Kill a §ccryomancer§r. These mages spawn in §6Mage Towers§r and drop gear pieces + school scrolls.", "", "§eReward:§r XP + a chance to drop an armor set or scroll."]
	quest.7600802B547E9192.quest_subtitle: "Ice mage"
	quest.7600802B547E9192.title: "Hunt Cryomancer"
	quest.7600B79D99D5BDFB.quest_desc: ["The mana spreader fires mana in a straight line until it hits a receiving block (pool, ring, etc). Without it, mana stays stuck in the generating flowers.", "botania:mana_spreader", "7600B79D99D5BDFB", "04AEA66CB8604161", "xp"]
	quest.7600B79D99D5BDFB.quest_subtitle: "Mana transfer"
	quest.7600B79D99D5BDFB.title: "Mana Spreader"
	quest.764506F56FACE661.quest_desc: ["World recipe: 1000mB §3water§r + 64 §asourceberry_bush§r in the mechanical_mixer → 250mB §dsource_fluid§r.", "", "This is an alternative source. You'll use source_fluid to make §dmana_pane§r (which unlocks the goggles) and any other Ars process.", "ars_nouveau:source_gem", "764506F56FACE661", "64C2BEBE79BC88E8", "xp"]
	quest.764506F56FACE661.quest_subtitle: "EQSMP cross-mod — alternative source"
	quest.764506F56FACE661.title: "Source Fluid via Create"
	quest.76572E2E36724C62.quest_desc: ["Chalk gold impure: 3 white_chalk + 1 spirit_attuned_gem + 1 gold_powder. Needed for afrit pentacle + djinni summoning.", "occultism:chalk_gold_impure", "76572E2E36724C62", "58EB4E671A9FCE99", "xp"]
	quest.76572E2E36724C62.quest_subtitle: "Fire chalk"
	quest.76572E2E36724C62.title: "Chalk Gold (Impure)"
	quest.76A7186246448689.quest_desc: [" The ritual_brazier requires a §dSpiritual Core§r in its craft.", "", "The brazier runs rituals: binding, summon, transmute, etc. Each ritual needs its specific ritual_tablet + ingredients.", "ars_nouveau:ritual_brazier", "76A7186246448689", "2E253964DE10681A", "xp"]
	quest.76A7186246448689.quest_subtitle: "F4 requirement — invokes rituals"
	quest.76A7186246448689.title: "Ritual Brazier"
	quest.7758EE6F6DBD44DD.quest_desc: ["§dChalk White§r traces the ritual glyphs on the ground. Produce the chalk in Occultism from §dImpure Glass§r and pigment.", "", "Without the chalk's symbols, the foliot has nowhere to anchor the purification."]
	quest.7758EE6F6DBD44DD.title: "White Chalk"
	quest.77C54F4775B47880.quest_desc: ["Apply it to a drawer to §eincrease the capacity§r of each slot.", "§7•§r The copper upgrade is the first step above standard.", "Stack upgrades to store far more of the same item."]
	quest.77C54F4775B47880.quest_subtitle: "+ capacity"
	quest.77C54F4775B47880.title: "Storage Upgrade (Copper)"
	quest.77F83D20DF0E6D10.quest_desc: ["The rosa arcana consumes nearby XP orbs. Combine it with a mob farm for steady mana.", "botania:rosa_arcana", "77F83D20DF0E6D10", "5BF29C8FE04D8635", "xp"]
	quest.77F83D20DF0E6D10.quest_subtitle: "XP-powered generator"
	quest.77F83D20DF0E6D10.title: "Rosa Arcana"
	quest.7827AF856CDF8A07.quest_desc: ["§5Archevoker§r — the boss version of the evoker. Multiple phases, aggressive summons.", "", "Drop: §6archevoker armor set§r + §6archevoker logbook§r (lore key)."]
	quest.7827AF856CDF8A07.quest_subtitle: "Supreme archmage"
	quest.7827AF856CDF8A07.title: "Boss: Archevoker"
	quest.7896F7D36063417E.quest_desc: ["Starter boss. Twilight Forest, mossy stone ruins. Prove your courage against the Serpent.", "", "§eReward:§r 20 XP levels + boss trophy"]
	quest.7896F7D36063417E.quest_subtitle: "First boss"
	quest.7896F7D36063417E.title: "Tier 1: Naga"
	quest.78C8FDB3350C9A9F.quest_desc: ["The base of Tombstone's magical tomes.", "tombstone:impregnated_diamond", "78C8FDB3350C9A9F", "3B0F3BD9180C31BF", "xp_levels"]
	quest.78C8FDB3350C9A9F.quest_subtitle: "Magical catalyst"
	quest.78C8FDB3350C9A9F.title: "Impregnated Diamond"
	quest.78CA4F614D45C40A.quest_desc: ["The basic storage block of Sophisticated Storage.", "§7•§r It accepts §eupgrades§r and tier upgrades, just like the backpacks.", "Start simple and raise the capacity as you need it."]
	quest.78CA4F614D45C40A.title: "Sophisticated Barrel"
	quest.7923CBBDBCE57052.quest_desc: ["Mana pearl: 1 ender_pearl tossed into a mana_pool with 8000 mana. Critical for mana_pylon, mana_ring upgrades, etc.", "botania:mana_pearl", "7923CBBDBCE57052", "18193BDAA2EF7742", "xp"]
	quest.7923CBBDBCE57052.quest_subtitle: "Mana crystal"
	quest.7923CBBDBCE57052.title: "Mana Pearl"
	quest.79D33DFD50A6872E.quest_desc: ["The novice book holds 1 spell of up to 5 glyphs. Craft it with 1 book + leather. Cast simple spells (lightning, projectile).", "ars_nouveau:novice_spell_book", "79D33DFD50A6872E", "59507919D31B0949", "xp"]
	quest.79D33DFD50A6872E.quest_subtitle: "First spell book"
	quest.79D33DFD50A6872E.title: "Novice Spell Book"
	quest.79EE0F2917A87655.quest_desc: ["Shafts carry rotation in a straight line. 6 andesite_alloy → 6 shafts. Combine with cogwheels to change direction.", "create:shaft", "79EE0F2917A87655", "6CA63ECEDAE3AEA2", "xp"]
	quest.79EE0F2917A87655.quest_subtitle: "Basic rotation transmission"
	quest.79EE0F2917A87655.title: "Shaft"
	quest.79F16AAE5980043F.quest_desc: ["The Engineer's first alloy. Here it requires a §dMagical Agglutinate§r at the center — anyone who hasn't yet walked the Druid's path will need to backtrack.", "", "Without this alloy, no machine takes shape. It's Create's gateway."]
	quest.79F16AAE5980043F.quest_subtitle: "Create's base alloy"
	quest.79F16AAE5980043F.title: "Andesite Alloy"
	quest.7A963B07D0C47857.quest_desc: ["A water wheel generates SU from flowing water. No fuel needed — just a river/waterfall. An intermediate rotation source.", "create:water_wheel", "7A963B07D0C47857", "3ABE210D46075D3D", "xp"]
	quest.7A963B07D0C47857.quest_subtitle: "Generation from flowing water"
	quest.7A963B07D0C47857.title: "Water Wheel"
	quest.7AB96DD073843E0C.quest_desc: ["Spawns in the End. Multiple projectiles.", "", "§eReward:§r 45 XP levels + elemental essence"]
	quest.7AB96DD073843E0C.quest_subtitle: "Pillar of the Void"
	quest.7AB96DD073843E0C.title: "Slay Obsidilith"
	quest.7AF1D14E42DAB699.quest_desc: ["The base material of Tombstone, dropped/obtained early.", "tombstone:grave_dust", "7AF1D14E42DAB699", "00D32C7A017AE5C3", "xp_levels", "1A2B3C4D5E6F0133", "1A2B3C4D5E6F0001", "random", "§2The magic of death§r", "5213BF6908CA8CE5", "tombstone:grave_dust", "item"]
	quest.7AF1D14E42DAB699.quest_subtitle: "§2The magic of death§r"
	quest.7AF1D14E42DAB699.title: "Grave Dust"
	quest.7AF57885CBAA8369.quest_desc: ["Drygmy charm + ritual → drygmy pet. Automatically collects creature drops from those penned nearby. The dream creature farm.", "ars_nouveau:drygmy_charm", "7AF57885CBAA8369", "6F1B1FB98CCA6636", "xp"]
	quest.7AF57885CBAA8369.quest_subtitle: "Familiar that collects creature loot"
	quest.7AF57885CBAA8369.title: "Drygmy Charm"
	quest.7B920AED7537D43A.title: "Calculation Processor"
	quest.7BF20FCBE6AE7B5C.quest_desc: ["The §eGold Backpack§r expands the inventory and available upgrades even further.", "§7•§r Made from the Iron Backpack.", "The intermediate step before diamond."]
	quest.7BF20FCBE6AE7B5C.title: "Gold Backpack"
	quest.7CA5AED17631A25D.quest_subtitle: "Autocraft structure"
	quest.7CA5AED17631A25D.title: "Crafting Unit"
	quest.7CB21B243D585645.quest_desc: ["The beginning will be &cmerciless&r. But each step in your progression brings you closer to &dredemption&r.", "Pay for your sins, grow stronger, and thrive in a world that does not forgive."]
	quest.7CB21B243D585645.title: "Survive the Penance"
	quest.7CC22A58F8FD2C3C.quest_desc: ["Jump ring (mundane belt slot or curio): jump higher. Combine with slow_fall potion for absurd mobility.", "ars_nouveau:jump_ring", "7CC22A58F8FD2C3C", "540FF89CF29BBEBE", "xp"]
	quest.7CC22A58F8FD2C3C.quest_subtitle: "Jump boost ring"
	quest.7CC22A58F8FD2C3C.title: "Jump Ring"
	quest.7D3EC01F11CE2101.quest_desc: ["Rechargeable item — doesn't get used up like a scroll.", "waystones:warp_stone", "7D3EC01F11CE2101", "6C5CF79B4E634CB8", "xp_levels"]
	quest.7D3EC01F11CE2101.quest_subtitle: "Reusable teleport"
	quest.7D3EC01F11CE2101.title: "Warp Stone"
	quest.7D495DAC8024FE2A.quest_desc: ["The pool is the heart of Botania — where all mana gathers.", "", "Here it isn't made from plain livingrock: the recipe calls for §6otherstone§r, that stone the occultists forge with spirit fire. Without walking the path of Occultism, the Druid can't fill his pool.", "botania:mana_pool", "7D495DAC8024FE2A", "6508B04E85DC9D7A", "xp"]
	quest.7D495DAC8024FE2A.quest_subtitle: "Cross-mod F1 — stores mana"
	quest.7D495DAC8024FE2A.title: "Mana Pool"
	quest.7D54ED633AB2E197.quest_desc: ["The corporea index takes requests via text/voice (\\\"give iron_ingot\\\"). Connect it to corporea_funnels linked to chests for automatic retrieval.", "botania:corporea_index", "7D54ED633AB2E197", "75C04D30DF75B8D3", "xp"]
	quest.7D54ED633AB2E197.quest_subtitle: "Botanical storage system"
	quest.7D54ED633AB2E197.title: "Corporea Index"
	quest.7D8F7AF6803F447B.quest_desc: ["There are ~30 Ars effects: damage, heal, break, place, harvest, ignite, freeze, etc. Each effect is WHAT the spell does.", "ars_nouveau:glyph_harvest", "7D8F7AF6803F447B", "245947E1480CE8EA", "xp"]
	quest.7D8F7AF6803F447B.quest_subtitle: "Spell effects"
	quest.7D8F7AF6803F447B.title: "Effect Collection (Glyphs)"
	quest.7DB04EBC9884A21E.quest_desc: ["The §eSkillet§r is for sautéing and frying.", "", "Meats, eggs and sautéed veggies come out of it.", "Combine it with fresh ingredients for quick, nutritious dishes."]
	quest.7DB04EBC9884A21E.title: "Skillet"
	quest.7DD9C27F9B0520BC.quest_subtitle: "Manages patterns"
	quest.7DD9C27F9B0520BC.title: "Pattern Access Terminal"
	quest.7E56147AB9F34877.quest_desc: ["The §eWarp Plate§r §bautomatically§r teleports anyone who steps on it.", "", "§7•§r Link it to a destination waystone and just step on it to travel.", "§7•§r Great for automating routes and shortcuts around the base."]
	quest.7E56147AB9F34877.quest_subtitle: "Automatic teleport on step"
	quest.7E56147AB9F34877.title: "Warp Plate"
	quest.7E6BB2C509910A40.quest_subtitle: "Djinni tier"
	quest.7E6BB2C509910A40.title: "Book of Binding (Djinni)"
	quest.7ECABB898739D877.quest_desc: ["The Mana Pool recipe was rewritten: §c5× occultism:otherstone§r (not livingrock).", "", "To open this gate you first need to process Otherstone via Occultism's Spirit Fire."]
	quest.7ECABB898739D877.quest_subtitle: "Cross-mod gate: Botania ↔ Occultism"
	quest.7ECABB898739D877.title: "Mana Pool (Otherstone)"
	quest.7F06C6FB7A3280C7.quest_desc: ["Pam's §eWild Gardens§r spawn scattered across the world according to the biome.", "", "Break them to harvest vegetables and seeds. There are §e6 types§r — Arid, Shaded, Frost, Windy, Soggy and Tropical — each in a different climate, with its own produce.", "", "§7Note: breaking a garden does §rnot§7 drop its block, only the produce. That's why each garden is marked manually.§r", "pamhc2crops:beanitem", "7F06C6FB7A3280C7", "011AEE3B6732E988", "xp_levels"]
	quest.7F06C6FB7A3280C7.quest_subtitle: "§2Harvest from the world§r"
	quest.7F06C6FB7A3280C7.title: "Found and broke the garden"
	quest.7F08A58B9D875A1F.quest_desc: ["§eIron's Spells 'n Spellbooks§r adds a classic magic RPG system: tomes, scrolls, schools, and mage gear.", "", "Start by grabbing the empty §6Spell Book§r — it's the foundation for inscribing spells.", "", "§a§lARS 'N SPELLS:§r this pack has the bridge mod that unifies §dArs Nouveau mana§r with §dIron's Spells mana§r. A single mana pool for both systems — invest in one source, use both!"]
	quest.7F08A58B9D875A1F.quest_subtitle: "Obtain your first tome"
	quest.7F08A58B9D875A1F.title: "The Apprentice Mage"
	quest.7F1249A3D3AAE8C7.quest_desc: ["A pump generates pressure to move fluids through pipes. Direction is set by right-click + wrench.", "create:mechanical_pump", "7F1249A3D3AAE8C7", "2BB4A4631FC9D779", "xp"]
	quest.7F1249A3D3AAE8C7.quest_subtitle: "Pressure for fluids"
	quest.7F1249A3D3AAE8C7.title: "Mechanical Pump"
	quest.7F1A766E7479A743.quest_desc: ["The §e64k Crafting Storage§r is the §6most robust component§r of an ME system crafting CPU.", "", "Slot it into an autocrafting CPU to expand how many §7•§r patterns and items a single task can hold.", "The bigger the component, the more complex the recipe the CPU can solve at once."]
	quest.7F1A766E7479A743.quest_subtitle: "Robust CPU"
	quest.7F1A766E7479A743.title: "64k Crafting Storage"
	quest.7F1D2D5C97E519E5.quest_desc: ["A spout pours fluids into items (potion bottles, water buckets, blaze cake mix). Works with belt/depot.", "create:spout", "7F1D2D5C97E519E5", "6517CF8286B828E7", "xp"]
	quest.7F1D2D5C97E519E5.quest_subtitle: "Fills items with fluid"
	quest.7F1D2D5C97E519E5.title: "Spout"
	quest.7F584AA483E1C48A.quest_desc: ["Make §e3§r diner foods from Pam's.", "pamhc2foodextended:baconmushroomburgeritem", "7F584AA483E1C48A", "6E62892AABFC9E8C", "xp_levels"]
	quest.7F584AA483E1C48A.quest_subtitle: "10 recipes in Pam's"
	quest.7F584AA483E1C48A.title: "Diner"
	quest.7F5912748974A533.quest_desc: ["The §eWarp Scroll§r takes you to §bany waystone§r you've already activated.", "", "§7•§r It is §2reusable§r, but goes on §6cooldown§r after each trip.", "§7•§r The free pass to move around your teleport network."]
	quest.7F5912748974A533.quest_subtitle: "Travel to any waystone"
	quest.7F5912748974A533.title: "Warp Scroll"
