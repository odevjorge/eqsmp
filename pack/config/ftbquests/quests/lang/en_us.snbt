	quest.6CC964B4A441195A.quest_desc: ["Head to the §etaigas and cold biomes§r in search of §6wild gardens§r.", "", "Among pines and snow grow rustic, hardy plants.", "Break them §7•§r to harvest ingredients that thrive in the cold."]
	quest.6CC964B4A441195A.title: "Found and broke the garden"
	quest.6CF9949F72E1227D.quest_desc: ["Sunken City in the ocean. The hardest boss — Eye of Abyss + sacrifice at the altar.", "", "§eReward:§r 80 XP levels + unique drop"]
	quest.6CF9949F72E1227D.quest_subtitle: "Abyssal Terror"
	quest.6CF9949F72E1227D.title: "Slay The Leviathan"
	quest.6D0DA215B4254C6C.quest_desc: ["§dArs 'n Spells§r connects the two mana systems into a single pool.", "", "§ePractical consequences:§r", "  §7• Ars Nouveau mana regen (Source) fuels Iron's spell casts.", "  §7• Iron's mana items (mana potions, regen rings) affect both.", "  §7• Source jars + spell book = a giant mana stockpile.", "", "Invest in either of the two sources — any mage build shares them."]
	quest.6D0DA215B4254C6C.quest_subtitle: "Ars Nouveau ↔ Iron's Spells bridge"
	quest.6D0DA215B4254C6C.title: "Ars 'n Spells — Unified Mana"
	quest.6D3B3AAF1A90F782.quest_desc: ["Steps the §eCopper Backpack§r up a notch: more slots and more upgrade slots.", "§7•§r Craft it by surrounding the previous backpack with iron.", "A good companion for mining and mid-sized expeditions."]
	quest.6D3B3AAF1A90F782.title: "Iron Backpack"
	quest.6D64C8F28DE5A911.quest_desc: ["The §bImbuement Chamber§r of Ars Nouveau condenses ambient Source into crystals and magical items.", "", "It's the chamber where the §ccorrupted crystal§r will be bathed in Source and purified."]
	quest.6D64C8F28DE5A911.title: "Imbuement Chamber"
	quest.6DDA4E6F1237B422.quest_desc: ["§dBook of Binding (Foliot)§r records the pact with a minor Occultism spirit. Write it with paper, leather, and spirit essence.", "", "It's one of the two reagents that draw up the purification ritual for the §cCursed Kinetic Core§r."]
	quest.6DDA4E6F1237B422.title: "Pact with the Foliot"
	quest.6DE8C1306C62F894.quest_desc: ["The Occultist's grimoire. Here you'll find all the pentacles, rituals and demons available to summon.", "", "Without it, you'll be wandering in the dark — always read it first."]
	quest.6DE8C1306C62F894.quest_subtitle: "The mod's guide"
	quest.6DE8C1306C62F894.title: "Dictionary of Spirits"
	quest.6E27D4CE7BC4377F.quest_desc: ["The Engineer saw the creation of the Stone as an &dequation&r to be solved by brute force. In his fortress of brass and zinc, his obsession manifested in building the &2Press of Infinity&r. Pushing Blaze Burners to the brink of explosion and generating &2Rotational Energy &rcapable of moving mountains, he tried to compress matter at the &2atomic&r level, seeking to forge divinity under absolute pressure and heat."]
	quest.6E27D4CE7BC4377F.quest_subtitle: "The Pursuit"
	quest.6E27D4CE7BC4377F.title: "The Engineer (Create)"
