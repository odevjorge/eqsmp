	quest.2705F4E4F163F94A.title: "ME Terminal"
	quest.2782C967594AF9B9.quest_desc: ["Alfsteel pickaxe: 3 alfsteel_ingot + 2 stick. Alfsteel comes from an alfheim_portal + manasteel recipe. Faster + sharper than iesnium.", "ars_nouveau:wilden_horn", "2782C967594AF9B9", "0F2F6C24B051A3F5", "xp"]
