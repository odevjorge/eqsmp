	quest.420FF5CF6EE201F7.title: "Fluid Pipe"
	quest.434EEEFE84713EF0.quest_desc: ["The Magebloom seed rarely drops from archwood leaves or can be bought from a wandering trader. Plant it on farmland to grow magebloom.", "ars_nouveau:magebloom_crop", "434EEEFE84713EF0", "72EA0BE17B708EE3", "xp"]
