	quest.231DA6F30E12A68C.quest_desc: ["Make §e4§r fresh juices from Pam's.", "pamhc2foodextended:apricotjuiceitem", "231DA6F30E12A68C", "7A75F21E658E7DE7", "xp_levels"]
	quest.231DA6F30E12A68C.quest_subtitle: "46 recipes in Pam's"
	quest.231DA6F30E12A68C.title: "Fresh Juices"
	quest.239774567E7A636A.quest_desc: ["Drygmies appear in archwood biomes. Kill around 5 for enough shards.", "ars_nouveau:drygmy_shard", "239774567E7A636A", "118032E8E3D96A23", "xp"]
	quest.239774567E7A636A.quest_subtitle: "Drop from drygmy"
	quest.239774567E7A636A.title: "Drygmy Shards"
	quest.239D5DEFA45318B1.quest_desc: ["§6Occultism§r has no entity bosses, but the §dLord of Stone§r (summoned via ritual) is the narrative equivalent.", "", "Perform the §6Summon Lord of Stone§r ritual with the proper sacrifice.", "", "Drop: §6dimensional_matrix§r — the key to other advanced rituals."]
	quest.239D5DEFA45318B1.quest_subtitle: "Demonic summoning ritual"
	quest.239D5DEFA45318B1.title: "Conjure the Lord of Stone"
	quest.23B6CC80F93CBE7A.quest_desc: ["§cTosses out§r the items you mark in the filter, the moment they come in.", "§7•§r Perfect for discarding cobblestone and junk while mining.", "Use it carefully: whatever falls in here is gone for good."]
	quest.23B6CC80F93CBE7A.quest_subtitle: "Tosses out filtered junk"
	quest.23B6CC80F93CBE7A.title: "Upgrade: Void"
